---
interface Props {
  items: Array<{
    question: string;
    answer: string;
  }>;
  title?: string;
  variant?: 'default' | 'gradient';
  backgroundColor?: 'white' | 'gray';
}

const { items, title, variant = 'default', backgroundColor = 'gray' } = Astro.props;

const bgClass = backgroundColor === 'gray' ? 'bg-gray-50' : 'bg-white';
const cardClass = variant === 'gradient'
  ? 'bg-gradient-to-r from-gray-50 to-white rounded p-6 border border-gray-200 hover:border-secondary/30 transition-all'
  : 'bg-white rounded shadow-md group';
---

<section class="py-20 px-4 {bgClass}">
  <div class="max-w-4xl mx-auto">
    {title && (
      <div class="text-center mb-12">
        <h2 class="text-4xl md:text-5xl font-bold text-secondary">
          {title}
        </h2>
      </div>
    )}
    <div class="space-y-4">
      {items.map((item) => (
<details class="{cardClass} group border-b border-gray-200">
  <summary class="p-6 cursor-pointer text-secondary font-semibold flex justify-between items-center transition-all duration-300 ease-in-out">
    {item.question}
    <svg class="w-5 h-5 text-secondary flex-shrink-0 ml-4 transform transition-transform duration-300 ease-out group-open:rotate-180 group-open:text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v12M6 12h12" class="group-open:hidden"></path>
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 12h12" class="hidden group-open:block"></path>
    </svg>
  </summary>
  {variant === 'gradient' ? (
    <p class="px-6 pb-6 text-black font-normal leading-relaxed">
      {item.answer}
    </p>
  ) : (
    <div class="grid-wrapper">
      <div class="px-6 pb-6 text-black font-normal">
        {item.answer}
      </div>
    </div>
  )}
</details>
      ))}
    </div>
  </div>
</section>

<style>
  details > summary {
    list-style: none;
  }
  details > summary::-webkit-details-marker {
    display: none;
  }
  details .grid-wrapper {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.3s ease-out;
  }
  details[open] .grid-wrapper {
    grid-template-rows: 1fr;
    transition: grid-template-rows 0.5s ease-in-out;
  }
  details .grid-wrapper > div {
    overflow: hidden;
  }


  /* Card hover effects for gradient variant */
  details.bg-gradient-to-r {
    transition: all 0.3s ease;
  }

  details.bg-gradient-to-r:hover {
    box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1);
  }

  /* Card hover effects for default variant */
  details.group {
    transition: all 0.3s ease;
  }

  details.group:hover {
    box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1);
  }
</style>
