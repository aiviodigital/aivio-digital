---
interface Props {
  items: Array<{
    question: string;
    answer: string;
  }>;
  title?: string;
  variant?: 'default' | 'gradient';
  backgroundColor?: 'white' | 'gray';
}

const { items, title, variant = 'default', backgroundColor = 'gray' } = Astro.props;

const bgClass = backgroundColor === 'gray' ? 'bg-gray-50' : 'bg-white';
const cardClass = variant === 'gradient'
  ? 'bg-gradient-to-r from-gray-50 to-white rounded p-6 border border-gray-200 hover:border-secondary/30 transition-all'
  : 'bg-white rounded shadow-md group';
---

<section class="py-20 px-4 {bgClass}">
  <div class="max-w-4xl mx-auto">
    {title && (
      <div class="text-center mb-12">
        <h2 class="text-4xl md:text-5xl font-bold text-gray-900">
          {title}
        </h2>
      </div>
    )}
    <div class="space-y-4">
      {items.map((item) => (
<details class="{cardClass} group">
  <summary class="p-6 cursor-pointer font-semibold text-gray-900 flex justify-between items-center transition-all duration-300 ease-in-out hover:translate-x-1">
    {item.question}
    <svg class="w-5 h-5 text-secondary flex-shrink-0 ml-4 transform transition-transform duration-300 ease-out group-open:rotate-180 group-open:text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
    </svg>
  </summary>
  {variant === 'gradient' ? (
    <p class="px-6 pb-6 text-gray-600 leading-relaxed animate-fade-in">
      {item.answer}
    </p>
  ) : (
    <div class="grid-wrapper">
      <div class="px-6 pb-6 text-gray-600 animate-fade-in">
        {item.answer}
      </div>
    </div>
  )}
</details>
      ))}
    </div>
  </div>
</section>

<style>
  details > summary {
    list-style: none;
  }
  details > summary::-webkit-details-marker {
    display: none;
  }
  details .grid-wrapper {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.3s ease-out;
  }
  details[open] .grid-wrapper {
    grid-template-rows: 1fr;
    transition: grid-template-rows 0.5s ease-in-out;
  }
  details .grid-wrapper > div {
    overflow: hidden;
  }

  /* Answer fade-in animation */
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(-10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-fade-in {
    animation: fadeIn 0.3s ease-out 0.1s both;
  }

  /* Card hover effects for gradient variant */
  details.bg-gradient-to-r {
    transition: all 0.3s ease;
  }

  details.bg-gradient-to-r:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1);
  }

  /* Card hover effects for default variant */
  details.group {
    transition: all 0.3s ease;
  }

  details.group:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1);
  }
</style>
