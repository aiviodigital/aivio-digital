---
import { translations } from '../i18n/index';
import { getMenuItems } from '../utils/menuItems';
import { EMAIL, PHONE_SIMPLE } from '../constants/contact';
import AivioImage from './common/AivioImage.astro';

interface Props {
  currentLang: string;
}

const { currentLang } = Astro.props;
const t = translations[currentLang as keyof typeof translations];
const currentYear = new Date().getFullYear();
const menuItems = getMenuItems(currentLang);
const copyrightText = t.footer.copyright.replace('{year}', String(currentYear));
---

<footer class="bg-[#ECEBEB] text-black py-12">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-8">
      <div>
        <AivioImage src="/assets/logo.png" alt="Aivio" className="w-80" />
        <h3 class="text-lg font-semibold mb-4">{t.footer.about}</h3>
        <p class="">{t.footer.aboutText}</p>
      </div>
      <div>
        <h3 class="text-lg font-semibold mb-4">{t.footer.quickLinks}</h3>
        <ul class="space-y-2 ">
          {menuItems.map(link => (
            <li><a href={link.href} class="hover:text-primary transition">{t.nav[link.key]}</a></li>
          ))}
        </ul>
      </div>
      <div>
        <h3 class="text-lg font-semibold mb-4">{t.footer.contact}</h3>
        <p class="">{t.footer.email}: {EMAIL}</p>
        <p class="">{t.footer.phone}: {PHONE_SIMPLE}</p>
        <div class="mt-4 flex gap-4">
          <div class="text-center">
            <AivioImage src="/assets/company_QR_code.png" alt="Company QR Code" className="w-24 h-24 rounded-lg mb-2" />
            <p class="text-xs text-gray-500">Company</p>
          </div>
          <div class="text-center">
            <AivioImage src="/assets/WeChat_QR_Code.jpg" alt="WeChat QR Code" className="w-24 h-24 rounded-lg mb-2" />
            <p class="text-xs text-gray-500">Wechat</p>
          </div>
        </div>
        <!-- Social Media Links -->
        <div class="mt-6">
          <p class="text-sm  mb-3">{t.footer.followUs || 'Follow Us'}</p>
          <div class="flex gap-4">
            <!-- X (Twitter) -->
            <a href="https://x.com/AivioDigital" target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-full flex items-center justify-center hover:scale-105 transition-transform">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
              </svg>
            </a>
            <!-- Facebook -->
            <a href="https://www.facebook.com/aiviodigital" target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-full flex items-center justify-center hover:scale-105 transition-transform">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
              </svg>
            </a>
            <!-- LinkedIn -->
            <a href="https://www.linkedin.com/company/aivio-digital/" target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-full flex items-center justify-center hover:scale-105 transition-transform">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
    <div class="border-t border-gray-800 pt-8 text-center ">
      <p>{copyrightText}</p>
    </div>
  </div>
</footer>
