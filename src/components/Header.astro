---
import { translations } from '../i18n/index';
import { getHeaderMenuItems, getMenuLink } from '../utils/menuItems';
import Button from './Button.astro';
import { EMAIL, PHONE_SIMPLE } from '../constants/contact';
import LangSwitch from './LangSwitch.astro';
import AivioImage from './common/AivioImage.astro';

interface Props {
  currentLang: string;
  currentPath?: string;
}

const { currentLang, currentPath = '/' } = Astro.props;
const t = translations[currentLang as keyof typeof translations];
const menuItems = getHeaderMenuItems(currentLang);

const isActive = (href: string) => {
  return currentPath.startsWith(href);
};
---
<div class="bg-secondary text-white py-2 font-medium">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex justify-end items-center gap-6 text-sm">
    <a href={`mailto:${EMAIL}`} class="flex items-center gap-2 hover:text-primary transition-color no-underline text-inherit">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
      </svg>
      {EMAIL}
    </a>
    <a href={`tel:${PHONE_SIMPLE.replace(/\s/g, '')}`} class="flex items-center gap-2 hover:text-primary transition-color no-underline text-inherit">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
      </svg>
      {PHONE_SIMPLE}
    </a>
  </div>
</div>

<header class="bg-white shadow-md sticky top-0 z-50 font-medium">
  <nav class="max-w-7xl mx-auto py-3">
    <div class="flex justify-between items-center">
      <a href={getMenuLink('', currentLang)} class="flex items-center gap-2 text-2xl font-bold text-secondary hover:text-secondaryDark transition no-underline text-inherit">
        <AivioImage src="/assets/logo.png" alt="Aivio Digital" className="w-40" />
      </a>

      <!-- Desktop Menu -->
      <ul class="hidden lg:flex items-center">
        {menuItems.map(item => (
          <li>
            <a
              href={item.href}
              class={`px-3 py-2 rounded-md whitespace-nowrap fw-500 font-medium transition ${
                isActive(item.href)
                  ? 'text-secondary'
                  : 'text-black hover:text-secondary'
              }`}
            >
              {t.nav[item.key as keyof typeof t.nav]}
            </a>
          </li>
        ))}
      </ul>

      <!-- Desktop Controls -->
      <div class="hidden lg:flex items-center gap-3">
        <!-- <LangSwitch currentLang={currentLang} variant="desktop" /> -->

        <Button href={getMenuLink('contact', currentLang)} variant="nav" size="lg">
          {t.nav.getAudit}
        </Button>
      </div>

      <div class="lg:hidden flex flex-col border-gray-200">
        <!-- <LangSwitch currentLang={currentLang} variant="mobile" /> -->

        <Button
          href={getMenuLink('contact', currentLang)}
          variant="nav"
          size="sm"
          class="mobile-menu-link w-full text-center"
        >
          Book Your Audit
        </Button>
      </div>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-button"
        class="lg:hidden p-2 rounded-lg hover:bg-gray-100 transition"
        aria-label="Toggle menu"
      >
        <svg class="w-6 h-6 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="lg:hidden max-h-0 overflow-hidden transition-all duration-300 ease-in-out">
      <ul class="flex flex-col gap-2 mt-4">
        {menuItems.map(item => (
          <li>
            <a
              href={item.href}
              class={`mobile-menu-link block px-4 py-3 rounded-lg font-medium text-sm transition border-l-4 no-underline text-inherit ${
                isActive(item.href)
                  ? 'text-secondary bg-secondary/5 border-secondary'
                  : 'text-gray-700 border-transparent hover:text-secondary hover:bg-gray-50'
              }`}
            >
              {t.nav[item.key as keyof typeof t.nav]}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </nav>
</header>

<!-- Mobile Menu Overlay -->
<div id="mobile-menu-overlay" class="fixed top-0 left-0 right-0 bottom-0 bg-black/50 opacity-0 invisible transition-all duration-300 ease-in-out z-40" onclick="closeMobileMenu()"></div>

<script>
  function toggleMobileMenu() {
    const menu = document.getElementById('mobile-menu');
    const overlay = document.getElementById('mobile-menu-overlay');
    const body = document.body;

    if (menu && overlay) {
      if (menu.classList.contains('open')) {
        closeMobileMenu();
      } else {
        menu.classList.add('open', 'max-h-[500px]');
        overlay.classList.add('open', 'opacity-100', 'visible');
        body.style.overflow = 'hidden';
      }
    }
  }

  function closeMobileMenu() {
    const menu = document.getElementById('mobile-menu');
    const overlay = document.getElementById('mobile-menu-overlay');
    const body = document.body;

    if (menu && overlay) {
      menu.classList.remove('open', 'max-h-[500px]');
      overlay.classList.remove('open', 'opacity-100', 'visible');
      body.style.overflow = '';
    }
  }

  // Mobile menu button
  const menuButton = document.getElementById('mobile-menu-button');
  if (menuButton) {
    menuButton.addEventListener('click', toggleMobileMenu);
  }

  // Mobile menu links
  const mobileLinks = document.querySelectorAll('.mobile-menu-link');
  mobileLinks.forEach(link => {
    link.addEventListener('click', closeMobileMenu);
  });

  // Overlay
  const overlay = document.getElementById('mobile-menu-overlay');
  if (overlay) {
    overlay.addEventListener('click', closeMobileMenu);
  }
</script>
