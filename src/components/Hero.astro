---
import AivioImage from './common/AivioImage.astro';

interface Props {
  title?: string;
  subtitle?: string;
  description?: string;
  titleHighlight?: string;
  currentLang?: 'en' | 'zh';
  image?: string;
}

const { title, subtitle, titleHighlight, image='' } = Astro.props;
---

<section class="flex flex-col md:flex-row">
  <!-- Left Side - Text Content with Beige Background -->
  <div class="bg-[#E8D5B7] flex-1 flex items-center justify-center px-8 md:px-16 py-16 text-secondary">
    <div class="">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold leading-tight mb-8">
        {title}
        {titleHighlight && <span class="">{titleHighlight}</span>}
      </h1>
      {subtitle && (
        <p class="text-lg text-gray-700 leading-relaxed mb-8 max-w-2xl">
          {subtitle}
        </p>
      )}
    </div>
  </div>

  <!-- Right Side - Hero Image -->
  {image && (
    <div class="relative flex-1 bg-gray-200 min-h-[400px] md:min-h-full">
      <AivioImage
        src={image}
        alt={title}
        className="absolute inset-0 w-full h-full object-cover object-center"
      />
    </div>
  )}
</section>
