---
import AivioImage from './common/AivioImage.astro';

interface Props {
  title?: string;
  subtitle?: string;
  description?: string;
  currentLang?: 'en' | 'zh';
  image?: string;
}

const { title, subtitle, image='' } = Astro.props;
---

<section class="grid md:grid-cols-2 min-h-[600px]">
  <!-- Left Side - Text Content with Beige Background -->
  <div class="bg-[#E8D5B7] flex items-center px-8 md:px-16 py-16 text-secondary">
    <div class="max-w-3xl">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold leading-tight mb-8">
        {title}
      </h1>
      <p class="text-sm capitalize tracking-wider mb-6 font-medium">
        {subtitle}
      </p>
    </div>
  </div>

  <!-- Right Side - Hero Image -->
  <div class="relative bg-gray-200 min-h-[400px] md:min-h-full">
    <AivioImage
      src={image}
      alt={title}
      className="absolute inset-0 w-full h-full object-cover"
    />
  </div>
</section>
