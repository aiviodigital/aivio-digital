---
interface Props {
  currentLang: string;
  variant?: 'desktop' | 'mobile';
}

import { languages } from '../i18n/index';

const { currentLang, variant = 'desktop' } = Astro.props;

const baseClasses = 'flex gap-1 items-center bg-gray-100 rounded-md p-1';
const buttonBaseClasses = 'px-3 py-1 rounded text-sm font-medium transition';

const containerClasses = variant === 'desktop' 
  ? baseClasses
  : `${baseClasses} w-full`;

const buttonClasses = (code: string) =>
  variant === 'desktop'
    ? `${buttonBaseClasses} ${currentLang === code ? 'bg-white text-secondary shadow-sm' : 'text-gray-600 hover:text-gray-900'}`
    : `${buttonBaseClasses} flex-1 py-2 ${currentLang === code ? 'bg-white text-secondary shadow-sm' : 'text-gray-600 hover:text-gray-900'}`;
---

<div class={containerClasses}>
  {Object.entries(languages).map(([code, name]) => (
    <button
      data-lang={code}
      class={`${buttonClasses(code)} ${variant === 'mobile' ? 'mobile-lang-switch-btn' : 'lang-switch-btn'}`}
    >
      {name}
    </button>
  ))}
</div>

<script define:vars={{ currentPath: '' }}>
  function switchLanguage(lang) {
    localStorage.setItem('lang', lang);

    // Get current path without language prefix
    const currentPathValue = window.location.pathname;
    const pathWithoutLang = currentPathValue.replace(/^\/?(en|zh)?\//, '');
    const newPath = `/${lang}/${pathWithoutLang}`;

    window.location.href = newPath;
  }

  // Desktop language switch buttons
  const langButtons = document.querySelectorAll('.lang-switch-btn');
  langButtons.forEach(btn => {
    const lang = btn.getAttribute('data-lang');
    if (lang) {
      btn.addEventListener('click', () => switchLanguage(lang));
    }
  });

  // Mobile language switch buttons
  const mobileLangButtons = document.querySelectorAll('.mobile-lang-switch-btn');
  mobileLangButtons.forEach(btn => {
    const lang = btn.getAttribute('data-lang');
    if (lang) {
      btn.addEventListener('click', () => {
        switchLanguage(lang);
        // Close mobile menu after language switch
        const menu = document.getElementById('mobile-menu');
        const overlay = document.getElementById('mobile-menu-overlay');
        const body = document.body;

        if (menu && overlay) {
          menu.classList.remove('open');
          overlay.classList.remove('open');
          body.style.overflow = '';
        }
      });
    }
  });
</script>
