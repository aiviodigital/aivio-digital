---
interface Props {
  threshold?: number;
}

const { threshold = 300 } = Astro.props;
---

<div id="scroll-to-top" class="group fixed bottom-[30px] right-[30px] w-[50px] h-[50px] rounded-full flex items-center justify-center cursor-pointer opacity-0 translate-y-[20px] transition-all duration-300 ease-[cubic-bezier(0.4,0,0.2,1)] shadow-lg z-[9999] bg-secondaryDark border-0 hover:-translate-y-[3px] hover:shadow-xl active:translate-y-0 sm:bottom-[20px] sm:right-[20px] sm:w-[44px] sm:h-[44px]">
  <svg class="arrow-icon w-6 h-6 text-white transition-transform duration-300 group-hover:-translate-y-0.5 sm:w-5 sm:h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18"></path>
  </svg>
</div>

<script define:vars={{ threshold }}>
  const button = document.getElementById('scroll-to-top');
  let ticking = false;

  const toggleButton = () => {
    const scrollTop = window.pageYOffset || document.documentElement.scrollTop;
    if (scrollTop > threshold) {
      button.classList.remove('opacity-0', 'translate-y-[20px]');
      button.classList.add('opacity-100', 'translate-y-0');
    } else {
      button.classList.add('opacity-0', 'translate-y-[20px]');
      button.classList.remove('opacity-100', 'translate-y-0');
    }
  };

  window.addEventListener('scroll', () => {
    if (!ticking) {
      window.requestAnimationFrame(() => {
        toggleButton();
        ticking = false;
      });
      ticking = true;
    }
  }, { passive: true });

  button.addEventListener('click', () => {
    window.scrollTo({
      top: 0,
      behavior: 'smooth'
    });
  });
</script>
