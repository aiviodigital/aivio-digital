---
interface Props {
  title: string;
  subtitle: string;
  buttonText: string;
}

import Button from '../Button.astro';
import { EMAIL } from '../../constants/contact';

const { title, subtitle, buttonText } = Astro.props;
---

<section class="py-20 px-4 bg-secondary">
  <div class="max-w-4xl mx-auto text-center">
    <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">
      {title}
    </h2>
    <p class="text-xl text-white/90 mb-10 max-w-2xl mx-auto leading-relaxed">
      {subtitle}
    </p>
    <Button
      href={`mailto:${EMAIL}?subject=Let's Talk About Growth`}
      variant="white"
      size="lg"
    >
      {buttonText}
    </Button>
  </div>
</section>
