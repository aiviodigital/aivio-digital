---
import Hero from '@/components/Hero.astro';

interface Props {
  label: string;
  title: string;
  titleHighlight: string;
  subtitle: string;
  image?: string;
}

const { label, title, titleHighlight, subtitle, image = '/assets/about/about-hero.png' } = Astro.props;
---

<Hero
  title={title}
  subtitle={subtitle}
  label={label}
  titleHighlight={titleHighlight}
  image={image}
/>
