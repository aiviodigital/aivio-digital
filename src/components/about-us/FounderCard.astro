---
interface Props {
  title: string;
  subtitle: string;
  quote: string;
  bio: string;
}

const { title, subtitle, quote, bio } = Astro.props;
---

<section class="py-20 px-4 bg-gray-50">
  <div class="max-w-5xl mx-auto">
    <div class="bg-white rounded-2xl shadow-lg p-8 md:p-12">
      <div class="flex items-start gap-6 mb-8">
        <div class="w-16 h-16 bg-secondary rounded-lg flex items-center justify-center flex-shrink-0">
          <span class="text-white text-2xl font-bold">A</span>
        </div>
        <div>
          <h3 class="text-xl font-bold text-gray-900">{title}</h3>
          <p class="text-sm text-gray-600">{subtitle}</p>
        </div>
      </div>

      <div class="border-l-4 border-blue-600 pl-6 mb-8">
        <p class="text-lg text-gray-700 leading-relaxed italic">
          "{quote}"
        </p>
      </div>

      <p class="text-gray-600 leading-relaxed">
        {bio}
      </p>
    </div>
  </div>
</section>
