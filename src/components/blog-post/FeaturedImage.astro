---
interface Props {
  src?: string;
  alt?: string;
}

const { src = '/assets/blog-placeholder.jpg', alt = 'Blog Featured Image' } = Astro.props;
---

<div class="bg-[#f8f9fa] py-10 px-0 sm:py-5">
  <div class="max-w-[1200px] mx-auto px-5">
    <img src={src} alt={alt} loading="eager" class="w-full object-cover rounded-[16px] bg-secondary sm:rounded-[12px]" />
  </div>
</div>
