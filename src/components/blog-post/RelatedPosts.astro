---
import BlogCard from '../blogs/BlogCard.astro';

interface Props {
  posts?: Array<{
    id: string;
    title: string;
    excerpt: string;
    image: string;
  }>;
  title?: string;
  currentLang: 'en' | 'zh';
  readMoreText: string;
}

const { posts = [], title = 'Related Articles', currentLang, readMoreText } = Astro.props;

// Map posts to match BlogCard interface
const blogPosts = posts.map(post => ({
  ...post,
  date: '',
  category: 'Blog'
}));
---

{posts.length > 0 && (
  <section class="py-16 sm:py-20 bg-white">
    <div class="max-w-7xl mx-auto px-5">
      <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-10 sm:mb-12 text-center">{title}</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {blogPosts.map((post) => (
          <BlogCard
            post={post}
            currentLang={currentLang}
            readMoreText={readMoreText}
          />
        ))}
      </div>
    </div>
  </section>
)}
