---
import { getImageUrl } from '../../i18n/blog';

interface BlogPost {
  id: string;
  title: string;
  excerpt: string;
  date: string;
  category: string;
  image: string;
}

interface Props {
  post: BlogPost;
  currentLang: 'en' | 'zh';
  readMoreText: string;
}

const { post, currentLang, readMoreText } = Astro.props;
const postUrl = `/${currentLang}/blog/${post.id}`;
const imageUrl = getImageUrl(post.image);
---

<a href={postUrl} class="group block bg-white rounded-2xl shadow-md hover:shadow-2xl transition-all duration-300 overflow-hidden border border-gray-100">
  <!-- Blog Image -->
  <div class="h-52 bg-gradient-to-br from-primary to-secondaryDark flex items-center justify-center relative overflow-hidden">
    <img
      src={imageUrl}
      alt={post.title}
      class="absolute inset-0 w-full h-full object-cover"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-black/10 group-hover:bg-black/0 transition-colors"></div>
  </div>

  <div class="p-6">
    <div class="flex items-center gap-3 mb-4">
      <span class="text-xs font-semibold text-white bg-secondary px-3 py-1.5 rounded shadow-sm">
        {post.category}
      </span>
      <span class="text-xs text-gray-500 font-medium flex items-center gap-1">
        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
        </svg>
        {post.date}
      </span>
    </div>

    <h2 class="text-xl font-bold text-gray-900 mb-3 group-hover:text-secondary transition-colors line-clamp-2">
      {post.title}
    </h2>

    <p class="text-gray-600 mb-6 line-clamp-3 leading-relaxed">
      {post.excerpt}
    </p>

    <div class="inline-flex items-center text-secondary font-semibold hover:text-secondaryDark transition-all duration-300 group/btn">
      {readMoreText}
      <svg class="w-4 h-4 ml-2 group-hover/btn:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
      </svg>
    </div>
  </div>
</a>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
