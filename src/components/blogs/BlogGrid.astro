---
import BlogCard from './BlogCard.astro';

interface BlogPost {
  id: string;
  title: string;
  excerpt: string;
  date: string;
  category: string;
  image: string;
}

interface Props {
  posts: BlogPost[];
  currentLang: 'en' | 'zh';
  readMoreText: string;
}

const { posts, currentLang, readMoreText } = Astro.props;
---

<section class="py-20 px-4 bg-gradient-to-br from-gray-50 to-white">
  <div class="max-w-7xl mx-auto">
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {posts.map((post) => (
        <BlogCard
          post={post}
          currentLang={currentLang}
          readMoreText={readMoreText}
        />
      ))}
    </div>
  </div>
</section>
