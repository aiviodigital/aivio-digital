---
interface Props {
  title: string;
  subtitle: string;
  buttonText: string;
  bgColor?: string;
}

import Button from '../Button.astro';
import { EMAIL } from '../../constants/contact';

const { title, subtitle, buttonText, bgColor = 'from-primary to-primaryDark' } = Astro.props;
---

<section class={`py-20 px-4 bg-secondary bg-[url(/assets/audit/audit-hero.png)]`}>
  <div class="max-w-3xl mx-auto text-center">
    <h2 class="text-3xl md:text-4xl font-bold mb-6 text-white">
      {title}
    </h2>
    <p class="text-xl text-white mb-8">
      {subtitle}
    </p>
    <Button
      href={`mailto:${EMAIL}?subject=Google Ads Audit Request`}
      variant="white"
      size="lg"
    >
      {buttonText}
    </Button>
  </div>
</section>
