---
interface Props {
  title: string;
  subtitle: string;
  buttonText: string;
  bgColor?: string;
}

import Button from '../Button.astro';
import { EMAIL } from '../../constants/contact';

const { title, subtitle, buttonText, bgColor = 'from-primary to-primaryDark' } = Astro.props;
---

<section class="py-20 px-4 relative overflow-hidden">
  <div class="absolute inset-0 bg-[url(/assets/audit/audit-hero.png)] bg-cover bg-center"></div>
  <div class="absolute inset-0 bg-primary/90 backdrop-blur-sm"></div>
  <div class="relative max-w-3xl mx-auto text-center z-10">
    <h2 class="text-3xl md:text-4xl font-bold mb-6 text-secondary">
      {title}
    </h2>
    <p class="text-xl text-secondary mb-8">
      {subtitle}
    </p>
    <Button
      href={'/en/contact'}
      variant="primary"
      size="lg"
    >
      {buttonText}
    </Button>
  </div>
</section>
