---
interface Props {
  title: string;
  subtitle: string;
  buttonText: string;
  bgColor?: string;
}

import Button from '../Button.astro';
import { EMAIL } from '../../constants/contact';

const { title, subtitle, buttonText, bgColor = 'from-primary to-primaryDark' } = Astro.props;
---

<section class={`py-20 px-4 bg-gradient-to-br ${bgColor}`}>
  <div class="max-w-4xl mx-auto text-center">
    <h2 class="text-3xl md:text-4xl font-bold mb-6 text-secondaryDark">
      {title}
    </h2>
    <p class="text-xl text-secondaryDark/40 mb-8 max-w-2xl mx-auto">
      {subtitle}
    </p>
    <Button
      href={`mailto:${EMAIL}?subject=Google Ads Audit Request`}
      variant="white"
      size="lg"
    >
      {buttonText}
    </Button>
  </div>
</section>
