---
interface Props {
  content: {
    twoPaths: {
      title: string;
      subtitle: string;
      toronto: {
        title: string;
        packageTitle: string;
        description: string;
        features: string[];
      };
      global: {
        title: string;
        packageTitle: string;
        description: string;
        features: string[];
      };
    };
  };
}

const { content } = Astro.props;
---

<!-- Two Paths Section -->
<section class="py-20 px-4 bg-gray-50">
  <div class="max-w-6xl mx-auto">
    <!-- Header -->
    <div class="text-center mb-4">
      <span class="inline-block text-xs font-semibold text-secondary uppercase tracking-wider mb-3">
        Service Tiers
      </span>
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-3">
        {content.twoPaths.title}
      </h2>
      <p class="text-base text-gray-600 max-w-2xl mx-auto">
        {content.twoPaths.subtitle}
      </p>
    </div>

    <!-- Two Columns -->
    <div class="grid md:grid-cols-2 gap-8 mt-12">
      <!-- Toronto Focus Column -->
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden hover:shadow-md transition-shadow">
        <div class="bg-gray-50 px-6 py-4 border-b border-gray-200">
          <span class="text-xs font-semibold text-secondary uppercase tracking-wider">
            {content.twoPaths.toronto.title}
          </span>
          <h3 class="text-xl font-bold text-gray-900 mt-1">{content.twoPaths.toronto.packageTitle}</h3>
        </div>
        <div class="p-6">
          <p class="text-sm text-gray-600 mb-6 leading-relaxed">
            {content.twoPaths.toronto.description}
          </p>
          <ul class="space-y-2.5">
            {content.twoPaths.toronto.features.map((feature) => (
              <li class="flex items-start text-sm">
                <svg class="w-4 h-4 text-secondary mr-2.5 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"></path>
                </svg>
                <span class="text-gray-700">{feature}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <!-- Global Reach Column -->
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden hover:shadow-md transition-shadow">
        <div class="bg-gray-50 px-6 py-4 border-b border-gray-200">
          <span class="text-xs font-semibold text-secondary uppercase tracking-wider">
            {content.twoPaths.global.title}
          </span>
          <h3 class="text-xl font-bold text-gray-900 mt-1">{content.twoPaths.global.packageTitle}</h3>
        </div>
        <div class="p-6">
          <p class="text-sm text-gray-600 mb-6 leading-relaxed">
            {content.twoPaths.global.description}
          </p>
          <ul class="space-y-2.5">
            {content.twoPaths.global.features.map((feature) => (
              <li class="flex items-start text-sm">
                <svg class="w-4 h-4 text-secondary mr-2.5 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"></path>
                </svg>
                <span class="text-gray-700">{feature}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>