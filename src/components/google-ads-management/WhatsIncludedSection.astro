---
import Icon from '@/components/common/Icon.astro';

interface Props {
  content: {
    whatsIncluded: {
      title: string;
      subtitle: string;
      items: Array<{
        title: string;
        description: string;
        icon: 'chart' | 'check' | 'edit';
      }>;
    };
  };
}

const { content } = Astro.props;

const icons = {
  chart: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z',
  check: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z',
  edit: 'M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z',
};
---

<!-- What's Included Section -->
<section class="py-20 px-4 bg-white">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-16">
      <p class="text-sm font-semibold text-secondary mb-4 tracking-wider uppercase">
        {content.whatsIncluded.title}
      </p>
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
        {content.whatsIncluded.subtitle}
      </h2>
    </div>

    <div class="grid md:grid-cols-3 gap-6">
      {content.whatsIncluded.items.map((item) => {
        const iconColors = {
          chart: { bg: 'bg-secondary/10', text: 'text-secondary' },
          check: { bg: 'bg-secondary/10', text: 'text-secondary' },
          edit: { bg: 'bg-secondary/10', text: 'text-secondary' },
        };
        const color = iconColors[item.icon] || iconColors.chart;

        return (
          <div class="bg-white p-8 rounded border border-gray-200 hover:border-secondary/30 hover:shadow-md transition-all group">
            <div class={`w-16 h-16 ${color.bg} rounded flex items-center justify-center mb-6 group-hover:bg-secondary group-hover:scale-110 transition-all`}>
              <Icon>
                <path d={icons[item.icon]} />
              </Icon>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">
              {item.title}
            </h3>
            <p class="text-gray-600 leading-relaxed text-sm">
              {item.description}
            </p>
          </div>
        );
      })}
    </div>
  </div>
</section>