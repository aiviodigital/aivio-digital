---
interface Props {
  content: {
    whatsIncluded: {
      title: string;
      subtitle: string;
      items: Array<{
        title: string;
        description: string;
        icon: 'chart' | 'check' | 'edit';
      }>;
    };
  };
}

const { content } = Astro.props;
---

<!-- What's Included Section -->
<section class="py-20 px-4 bg-gradient-to-br from-gray-50 to-white">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
        {content.whatsIncluded.title}
      </h2>
      <p class="text-lg text-gray-600 max-w-3xl mx-auto">
        {content.whatsIncluded.subtitle}
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-8">
      {content.whatsIncluded.items.map((item) => {
        const iconColors = {
          chart: { bg: 'bg-blue-100', text: 'text-blue-600' },
          check: { bg: 'bg-green-100', text: 'text-green-600' },
          edit: { bg: 'bg-purple-100', text: 'text-purple-600' },
        };
        const color = iconColors[item.icon] || iconColors.chart;
        
        return (
          <div class="bg-white p-8 rounded-2xl shadow-lg border border-gray-100 hover:shadow-xl transition-shadow">
            <div class={`w-16 h-16 rounded-full ${color.bg} flex items-center justify-center mb-6 mx-auto`}>
              {item.icon === 'chart' && (
                <svg class={`w-8 h-8 ${color.text}`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
                </svg>
              )}
              {item.icon === 'check' && (
                <svg class={`w-8 h-8 ${color.text}`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
              )}
              {item.icon === 'edit' && (
                <svg class={`w-8 h-8 ${color.text}`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                </svg>
              )}
            </div>
            <h3 class="text-2xl font-bold text-gray-900 mb-4 text-center">{item.title}</h3>
            <p class="text-gray-600 text-center">
              {item.description}
            </p>
          </div>
        );
      })}
    </div>
  </div>
</section>