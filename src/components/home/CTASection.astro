---
import Button from '../Button.astro';
import { EMAIL } from '../../constants/contact';

interface Props {
  currentLang: 'en' | 'zh';
}

const { currentLang } = Astro.props;
---

<section class="py-20 px-4 bg-secondary">
  <div class="max-w-7xl mx-auto">
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <div class="text-white">
        <span class="inline-block bg-white text-secondary px-4 py-2 rounded text-sm font-semibold mb-6">
          Get Started with Aivio Today
        </span>
        <h2 class="text-3xl md:text-4xl font-bold mb-6">
          Get a Precise Google Ads Audit Today
        </h2>
        <p class="text-white/90 leading-relaxed mb-8">
          Contact Aivio Digital Marketing Agency to schedule a detailed Google Ads consultation or audit. Let data-driven strategy, execution, and optimized results move your business forward in North America.
        </p>
        <div class="space-y-4">
          <Button href={`mailto:${EMAIL}?subject=Google Ads Audit Request`} variant="primary" size="lg">
            Email
          </Button>
        </div>
      </div>
      <div>
        <img
          src="/assets/home/H-14.png"
          alt="Get Started Today"
          class="w-full h-auto rounded-lg shadow-2xl"
        />
      </div>
    </div>
  </div>
</section>
