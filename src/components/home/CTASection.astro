---
import Button from '../Button.astro';
import { EMAIL } from '../../constants/contact';
import { translations } from '../../i18n';

interface Props {
  currentLang: 'en' | 'zh';
}

const { currentLang } = Astro.props;
const t = translations[currentLang];
---

<section class="py-20 px-4 bg-secondary relative overflow-hidden">
  <div class="absolute inset-0">
    <img
      src="/assets/home/H-14.png"
      alt=""
      class="w-full h-full object-cover blur-sm scale-105"
      aria-hidden="true"
    />
    <div class="absolute inset-0 bg-secondary/90"></div>
  </div>
  <div class="max-w-7xl mx-auto relative z-10">
    <div class="text-white max-w-4xl text-center mx-auto">
      <h2 class="text-3xl md:text-4xl font-bold mb-6">
        {t.cta.title}
      </h2>
      <p class="text-white/90 leading-relaxed mb-8">
        {t.cta.description}
      </p>
      <div class="space-y-4">
        <Button href={`mailto:${EMAIL}?subject=Google Ads Audit Request`} variant="primary" size="lg">
          {t.cta.button}
        </Button>
      </div>
    </div>
  </div>
</section>
