---
import { translations } from '../i18n/index';
import { getMenuLink } from '../utils/menuItems';
import Button from './Button.astro';

interface Props {
  currentLang: string;
}

const { currentLang } = Astro.props;
const t = translations[currentLang as keyof typeof translations];
---

<section class="py-20 bg-secondaryDark">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-white text-center">
    <h2 class="text-4xl md:text-5xl font-bold mb-6">{t.finalCta.title}</h2>
    <p class="text-xl mb-10">{t.finalCta.subtitle}</p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
      <Button
        href={getMenuLink('contact', currentLang)}
        variant="secondary"
        size="lg"
      >
        {t.finalCta.button}
      </Button>
      <a href="tel:6476251375" class="text-white font-semibold text-lg hover:text-white/30 transition flex items-center gap-2">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
        </svg>
        {t.finalCta.orCall}
      </a>
    </div>
  </div>
</section>
