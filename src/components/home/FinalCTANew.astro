---
import Button from '../Button.astro';
import { EMAIL } from '../../constants/contact';

interface Props {
  currentLang: 'en' | 'zh';
}

const { currentLang } = Astro.props;
---

<section class="py-20 px-4 bg-white">
  <div class="max-w-4xl mx-auto text-center">
    <p class="text-gray-600 text-sm uppercase tracking-wider mb-4">
      If you're ready to elevate your Google Ads performance and track your goals
    </p>
    <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-12">
      Get a Precise Google Ads Audit Today
    </h2>

    <div class="bg-gradient-to-br from-gray-50 to-white rounded-2xl p-8 md:p-12 shadow-xl border border-gray-200">
      <p class="text-lg text-gray-700 leading-relaxed mb-8">
        Contact Aivio Digital Marketing Agency to schedule a detailed Google Ads consultation or audit. Let data-driven strategy, execution, and optimized results move your business forward in North America.
      </p>
      <Button href={`mailto:${EMAIL}?subject=Google Ads Consultation`} variant="secondary" size="lg" class="mx-auto">
        Get Your Free Consultation
      </Button>
    </div>
  </div>
</section>
