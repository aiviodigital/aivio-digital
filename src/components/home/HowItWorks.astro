---
import { translations } from '../../i18n/index';
import AivioImage from '@/components/common/AivioImage.astro';
import Icon from '../common/Icon.astro';

interface Props {
  currentLang: string;
}

const { currentLang } = Astro.props;
const t = translations[currentLang as keyof typeof translations];

const steps = [
  { ...t.howItWorks.audit, icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4' },
  { ...t.howItWorks.fixAndBuild, icon: 'M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31 2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z' },
  { ...t.howItWorks.manageAndOptimize, icon: 'M13 7h8m0 0v8m0-8l-8 8-4-4-6 6' },
];
---

<section class="py-20 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="text-4xl md:text-5xl font-bold mb-4 text-gray-900">{t.howItWorks.title}</h2>
      <p class="text-xl text-gray-600 max-w-2xl mx-auto">{t.howItWorks.subtitle}</p>
    </div>

    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <!-- Left Side: Steps -->
      <div class="space-y-8">
        {steps.map((step, index) => (
          <div class="flex gap-6 items-start bg-white rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow">
            <div class="flex-shrink-0">
              <Icon><path d={step.icon} /></Icon>
              {/* <div class="w-14 h-14 bg-primary rounded-lg flex items-center justify-center">
                <svg class="w-9 h-9 text-black" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={step.icon}></path>
                </svg>
              </div> */}
            </div>
            <div class="flex-1">
              <div class="flex items-center gap-3 mb-2 text-secondary">
                <span class="text-2xl font-bold">{step.step}</span>
                <h3 class="text-xl font-bold">{step.title}</h3>
              </div>
              <p class="text-gray-600 leading-relaxed">{step.description}</p>
            </div>
          </div>
        ))}
        
        <div class="rounded-xl p-6 text-secondary">
          <p class="text-center font-bold text-xl">{t.howItWorks.noContract}</p>
        </div>
      </div>

      <!-- Right Side: Image -->
      <div class="relative">
        <div class="aspect-square rounded-2xl overflow-hidden shadow-2xl">
          <AivioImage
            src="/assets/home/insight.png"
            alt={t.howItWorks.title}
            className="w-full h-full object-cover"
          />
        </div>
        <!-- Decorative elements -->
        <div class="absolute -top-4 -right-4 w-24 h-24 bg-secondary/20 rounded-full blur-2xl"></div>
        <div class="absolute -bottom-4 -left-4 w-32 h-32 bg-yellow-400/20 rounded-full blur-2xl"></div>
      </div>
    </div>
  </div>
</section>
