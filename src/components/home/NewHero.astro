---
import { translations } from '../../i18n';
import Hero from '../Hero.astro';

interface Props {
  currentLang: 'en' | 'zh';
}

const { currentLang } = Astro.props;
const t = translations[currentLang];
---

<Hero 
  title={t.hero.title}
  subtitle={t.hero.subtitle}
  image="/assets/home/hero.png"
/>
