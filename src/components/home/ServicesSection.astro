---
import { translations } from '../../i18n';
import Button from '../Button.astro';
import AivioImage from '../common/AivioImage.astro';

interface Props {
  currentLang: 'en' | 'zh';
}

const { currentLang } = Astro.props;
const t = translations[currentLang];
---

<section class="py-16 px-4 bg-white">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-12">
      <!-- <span class="inline-block bg-secondary text-white px-4 py-2 rounded text-sm font-semibold mb-4">
        {t.services.badge}
      </span> -->
      <h2 class="text-3xl max-w-5xl mx-auto md:text-4xl font-bold text-gray-900 mb-8">
        {t.services.title}
      </h2>
      <p class="max-w-3xl mx-auto leading-relaxed mb-4 text-lg">
        {t.services.description}
      </p>
      <p class="text-secondary font-semibold text-sm">
        {t.services.cta}
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-6 mt-12">
      {t.services.cards.map((card, index) => (
        <div class="bg-white rounded-lg shadow-lg overflow-hidden hover:shadow-xl transition-shadow duration-300">
          <AivioImage src={`/assets/home/H-${4 + index}.png`} alt={card.alt} className="w-full h-48 object-cover" />
          <div class="p-6 text-center">
            <h3 class="text-xl font-bold text-secondary mb-3">{card.title}</h3>
            <p class="text-gray-600 mb-4 leading-relaxed">
              {card.description}
            </p>
            {/* <Button href={`/${currentLang}/${index === 2 ? 'case-study' : 'google-ads-' + (index === 0 ? 'audit' : 'management')}`} variant='secondary'>{card.cta}</Button> */}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
