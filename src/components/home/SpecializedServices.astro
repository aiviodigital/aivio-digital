---
import { translations } from '../../i18n';
import type { Language } from '../../i18n';
import Button from '../Button.astro';
import AivioImage from '../common/AivioImage.astro';

interface Props {
  currentLang: Language;
}

const { currentLang } = Astro.props;
const t = translations[currentLang];
---

<section class="py-16 px-4 bg-white">
  <div class="max-w-7xl mx-auto">
    <div class="grid md:grid-cols-3 gap-8">
      {t.specialized.map((service, index) => (
        <div class="text-center group">
          <div class="mb-6 overflow-hidden rounded-lg shadow-md">
            <AivioImage
              src={`/assets/home/H-${7 + index}.png`}
              alt={service.title}
              className="w-full h-56 object-cover group-hover:scale-105 transition-transform duration-300"
            />
          </div>
          <h3 class="text-xl font-bold text-secondary mb-3">{service.title}</h3>
          <p class="text-gray-600 leading-relaxed mb-4">{service.description}</p>
          {/* <Button
          variant='secondary'
            href={`/${currentLang}${service.url}`}
          >
            {service.cta}
          </Button> */}
        </div>
      ))}
    </div>
  </div>
</section>
