---
import Layout from '@/layouts/Layout.astro';
import NewHero from '@/components/home/NewHero.astro';
import ServicesSection from '@/components/home/ServicesSection.astro';
import SpecializedServices from '@/components/home/SpecializedServices.astro';
import PortfolioGallery from '@/components/home/PortfolioGallery.astro';
import CTASection from '@/components/home/CTASection.astro';
import FinalCTANew from '@/components/home/FinalCTANew.astro';
import { translations } from '@/i18n/index';

// Get the language from the URL parameter
const { lang } = Astro.params;
const currentLang = (lang || 'en') as 'en' | 'zh';
const currentPath = Astro.url.pathname;
const t = translations[currentLang as keyof typeof translations];
const pageTitle = t.pageTitle.home;
const pageMeta = t.pageMeta.home;

// Generate static paths for language variants
export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },  // /en for English
    { params: { lang: 'zh' } },  // /zh for Chinese
  ];
}
---

<Layout title={pageTitle} description={pageMeta.description} keywords={pageMeta.keywords} lang={currentLang} currentLang={currentLang} currentPath={currentPath}>
  <main>
    <NewHero currentLang={currentLang} />
    <ServicesSection currentLang={currentLang} />
    <SpecializedServices />
    <PortfolioGallery />
    <CTASection currentLang={currentLang} />
    <FinalCTANew currentLang={currentLang} />
  </main>
</Layout>

<style>
  main {
    width: 100%;
  }
</style>
