---
import Layout from '@/layouts/Layout.astro';
import HomePageContent from '@/components/home/HomePageContent.astro';
import { translations } from '@/i18n/index';

// Get the language from the URL parameter
const { lang } = Astro.params;
const currentLang = (lang || 'en') as 'en' | 'zh';
const currentPath = Astro.url.pathname;
const t = translations[currentLang as keyof typeof translations];
const pageTitle = t.pageTitle.home;
const pageMeta = t.pageMeta.home;

// Generate static paths for language variants
export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },  // /en for English
    { params: { lang: 'zh' } },  // /zh for Chinese
  ];
}
---

<Layout title={pageTitle} description={pageMeta.description} keywords={pageMeta.keywords} lang={currentLang} currentLang={currentLang} currentPath={currentPath}>
  <HomePageContent currentLang={currentLang} />
</Layout>
