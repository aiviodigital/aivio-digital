---
import Layout from '../../layouts/Layout.astro';
import { translations } from '../../i18n';

const { lang } = Astro.params;
const currentLang = (lang || 'en') as 'en' | 'zh';
const currentPath = Astro.url.pathname;
const t = translations[currentLang];
const pageTitle = t.pageTitle.caseStudy;
const pageMeta = t.pageMeta.caseStudy;

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'zh' } },
  ];
}
---

<Layout title={pageTitle} description={pageMeta.description} keywords={pageMeta.keywords} lang={currentLang} currentLang={currentLang} currentPath={currentPath}>
  <main class="min-h-screen bg-white">
    <!-- Hero Section with Beige Background -->
    <section class="bg-[#E8D5B7] py-16 px-4">
      <div class="max-w-7xl mx-auto">
        <div class="grid md:grid-cols-2 gap-12 items-center">
          <!-- Left: Large Hero Image -->
          <div class="order-2 md:order-1">
            <img
              src="/assets/case/hero-analytics.jpg"
              alt="Google Ads Analytics Dashboard"
              class="w-full h-auto rounded-lg shadow-2xl"
              onerror="this.src='/assets/google_ads_audit.png'"
            />
          </div>

          <!-- Right: Title Text -->
          <div class="order-1 md:order-2">
            <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-secondary leading-tight">
              Proven Google Ads Campaigns Driving Measurable Growth
            </h1>
          </div>
        </div>
      </div>
    </section>

    <!-- Dark Green Section with Multiple Images -->
    <section class="bg-secondary py-20 px-4">
      <div class="max-w-7xl mx-auto">
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-6">
          <div class="aspect-[4/3] rounded-lg overflow-hidden shadow-lg">
            <img
              src="/assets/case/analytics-1.jpg"
              alt="Campaign Analytics"
              class="w-full h-full object-cover"
              onerror="this.src='/assets/home/H-4.png'"
            />
          </div>
          <div class="aspect-[4/3] rounded-lg overflow-hidden shadow-lg">
            <img
              src="/assets/case/chart-analysis.jpg"
              alt="Chart Analysis"
              class="w-full h-full object-cover"
              onerror="this.src='/assets/home/H-5.png'"
            />
          </div>
          <div class="aspect-[4/3] rounded-lg overflow-hidden shadow-lg">
            <img
              src="/assets/case/team-presentation.jpg"
              alt="Team Presentation"
              class="w-full h-full object-cover"
              onerror="this.src='/assets/home/H-6.png'"
            />
          </div>
          <div class="aspect-[4/3] rounded-lg overflow-hidden shadow-lg">
            <img
              src="/assets/case/laptop-analytics.jpg"
              alt="Laptop Analytics"
              class="w-full h-full object-cover"
              onerror="this.src='/assets/home/H-3.png'"
            />
          </div>
          <div class="aspect-[4/3] rounded-lg overflow-hidden shadow-lg">
            <img
              src="/assets/case/tablet-charts.jpg"
              alt="Tablet Charts"
              class="w-full h-full object-cover"
              onerror="this.src='/assets/home/H-1.png'"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- White Section with Metrics -->
    <section class="bg-white py-20 px-4">
      <div class="max-w-7xl mx-auto">
        <div class="text-center mb-16">
          <p class="text-sm text-gray-600 uppercase tracking-wider mb-2">
            Proven Google Ads Performance Metrics
          </p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-12">
          <!-- Metric 1 -->
          <div class="text-center">
            <h3 class="text-4xl md:text-5xl font-bold text-secondary mb-4">326%</h3>
            <p class="text-xl font-semibold text-gray-900 mb-2">Average ROI Increase</p>
            <p class="text-sm text-gray-600 leading-relaxed">
              Clients see a consistent 326% return on ad spend within six months of campaign optimization.
            </p>
          </div>

          <!-- Metric 2 -->
          <div class="text-center">
            <h3 class="text-4xl md:text-5xl font-bold text-secondary mb-4">45%</h3>
            <p class="text-xl font-semibold text-gray-900 mb-2">Reduction in Cost Per Acquisition</p>
            <p class="text-sm text-gray-600 leading-relaxed">
              Strategic bid adjustments and targeting refinements cut acquisition costs nearly in half.
            </p>
          </div>

          <!-- Metric 3 -->
          <div class="text-center">
            <h3 class="text-4xl md:text-5xl font-bold text-secondary mb-4">150+</h3>
            <p class="text-xl font-semibold text-gray-900 mb-2">Campaigns Managed</p>
            <p class="text-sm text-gray-600 leading-relaxed">
              Extensive experience managing over 150 Google Ads campaigns tailored to SMEs and manufacturers.
            </p>
          </div>

          <!-- Metric 4 -->
          <div class="text-center">
            <h3 class="text-4xl md:text-5xl font-bold text-secondary mb-4">78%</h3>
            <p class="text-xl font-semibold text-gray-900 mb-2">Client Retention Rate</p>
            <p class="text-sm text-gray-600 leading-relaxed">
              Long-term partnerships reflect satisfaction and sustained campaign success across diverse industries.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Bottom Section with Team Meeting Image -->
    <section class="relative py-32 px-4">
      <!-- Background Image -->
      <div class="absolute inset-0">
        <img
          src="/assets/case/team-meeting.jpg"
          alt="Proven Google Ads Driving Business Growth"
          class="w-full h-full object-cover"
          onerror="this.src='/assets/home/H-14.png'"
        />
        <div class="absolute inset-0 bg-black/40"></div>
      </div>

      <!-- Content Overlay -->
      <div class="relative z-10 max-w-4xl mx-auto text-center">
        <h2 class="text-4xl md:text-5xl font-bold text-white mb-6">
          Proven Google Ads Driving Business Growth
        </h2>
        <a
          href={`/${currentLang}/contact`}
          class="inline-block bg-white text-secondary font-semibold px-8 py-4 rounded-lg hover:bg-secondary/10 transition-colors text-lg shadow-md hover:shadow-lg"
        >
          Request Consultation
        </a>
      </div>
    </section>
  </main>
</Layout>

<style>
  main {
    width: 100%;
  }
</style>
