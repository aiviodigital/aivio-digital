---
import Layout from '../../layouts/Layout.astro';
import { translations } from '../../i18n';
import Hero from '@/components/Hero.astro';
import AivioImage from '@/components/common/AivioImage.astro';

const { lang } = Astro.params;
const currentLang = (lang || 'en') as 'en' | 'zh';
const currentPath = Astro.url.pathname;
const t = translations[currentLang];
const pageTitle = t.pageTitle.caseStudy;
const pageMeta = t.pageMeta.caseStudy;

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'zh' } },
  ];
}
---

<Layout title={pageTitle} description={pageMeta.description} keywords={pageMeta.keywords} lang={currentLang} currentLang={currentLang} currentPath={currentPath}>
  <main class="min-h-screen bg-white">
    <!-- Hero Section with Beige Background -->
    <Hero
      title={t.caseStudy.hero.title}
      subtitle={t.caseStudy.hero.subtitle}
      image="/assets/case/case-1.png"
    />

    <!-- Dark Green Section with Multiple Images -->
    <section class="bg-secondary py-20 px-4">
      <div class="max-w-7xl mx-auto">
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-6">
          <div class="aspect-[4/3] rounded-lg overflow-hidden shadow-lg">
            <AivioImage
              src="/assets/case/case-2.png"
              alt={t.caseStudy.hero.alt.analytics}
              className="w-full h-full object-cover"
            />
          </div>
          <div class="aspect-[4/3] rounded-lg overflow-hidden shadow-lg">
            <AivioImage
              src="/assets/case/case-3.png"
              alt={t.caseStudy.hero.alt.chart}
              className="w-full h-full object-cover"
            />
          </div>
          <div class="aspect-[4/3] rounded-lg overflow-hidden shadow-lg">
            <AivioImage
              src="/assets/case/case-10.png"
              alt={t.caseStudy.hero.alt.team}
              className="w-full h-full object-cover"
            />
          </div>
          <div class="aspect-[4/3] rounded-lg overflow-hidden shadow-lg">
            <AivioImage
              src="/assets/case/case-5.png"
              alt={t.caseStudy.hero.alt.laptop}
              className="w-full h-full object-cover"
            />
          </div>
          <div class="aspect-[4/3] rounded-lg overflow-hidden shadow-lg">
            <AivioImage
              src="/assets/case/case-6.png"
              alt={t.caseStudy.hero.alt.tablet}
              className="w-full h-full object-cover"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- White Section with Metrics -->
    <section class="bg-white py-20 px-4">
      <div class="max-w-7xl mx-auto">
        <div class="text-center mb-16">
          <p class="text-sm text-gray-600 uppercase tracking-wider mb-2">
            {t.caseStudy.metrics.title}
          </p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-12">
          {t.caseStudy.metrics.items.map((metric) => (
            <div class="text-center">
              <h3 class="text-4xl md:text-5xl font-bold text-secondary mb-4">{metric.value}</h3>
              <p class="text-xl font-semibold text-gray-900 mb-2">{metric.title}</p>
              <p class="text-sm text-gray-600 leading-relaxed">
                {metric.description}
              </p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Case Studies List Section -->
    <section class="py-20 px-4 bg-gray-50">
      <div class="max-w-7xl mx-auto">
        <div class="text-center mb-12">
          <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
            {t.caseStudies.listTitle}
          </h2>
          <p class="text-base text-gray-600 max-w-2xl mx-auto">
            {t.caseStudies.listSubtitle}
          </p>
        </div>

        <div class="grid md:grid-cols-2 gap-8">
          {t.caseStudies.list.map((caseStudy) => (
            <a
              href={`/${currentLang}/case-study/${caseStudy.slug}`}
              class="bg-white rounded-lg shadow-md overflow-hidden hover:shadow-xl transition-shadow duration-300 group"
            >
              <div class="p-8">
                <div class="flex items-center gap-2 text-sm text-secondary mb-4">
                  <span class="bg-secondary/10 px-3 py-1 rounded-full">{caseStudy.industry}</span>
                  <span class="text-gray-400">•</span>
                  <span class="text-gray-600">{caseStudy.location}</span>
                </div>
                <h3 class="text-xl font-bold text-gray-900 mb-4 group-hover:text-secondary transition-colors">
                  {caseStudy.title}
                </h3>
                <p class="text-gray-600 mb-6 leading-relaxed">
                  {caseStudy.summary}
                </p>
                <div class="flex flex-wrap gap-2 mb-6">
                  {caseStudy.tags.map((tag) => (
                    <span class="bg-gray-100 text-gray-600 text-xs px-3 py-1 rounded-full">
                      {tag}
                    </span>
                  ))}
                </div>
                <div class="flex items-center justify-between">
                  <div class="flex gap-4">
                    {caseStudy.results.map((result) => (
                      <span class="text-xs font-semibold text-secondary">
                        {result}
                      </span>
                    ))}
                  </div>
                  <span class="text-secondary font-semibold text-sm flex items-center gap-1 group-hover:gap-2 transition-all">
                    {t.caseStudies.viewDetails}
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                    </svg>
                  </span>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Bottom Section with Team Meeting Image -->
    <section class="relative py-32 px-4">
      <!-- Background Image -->
      <div class="absolute inset-0">
        <AivioImage
          src="/assets/case/case-7.png"
          alt={t.caseStudy.bottomSection.alt}
          className="w-full h-full object-cover"
        />
        <div class="absolute inset-0 bg-black/40"></div>
      </div>

      <!-- Content Overlay -->
      <div class="relative z-10 max-w-4xl mx-auto text-center">
        <h2 class="text-4xl md:text-5xl font-bold text-white mb-6">
          {t.caseStudy.bottomSection.title}
        </h2>
        <a
          href={`/${currentLang}/contact`}
          class="inline-block bg-white text-secondary font-semibold px-8 py-4 rounded-lg hover:text-white hover:bg-secondary transition-colors text-lg shadow-md hover:shadow-lg"
        >
          {t.caseStudy.bottomSection.button}
        </a>
      </div>
    </section>
  </main>
</Layout>

<style>
  main {
    width: 100%;
  }
</style>
