---
import Layout from '../../../layouts/Layout.astro';
import { translations } from '../../../i18n';
import AivioImage from '../../../components/common/AivioImage.astro';
import Button from '@/components/Button.astro';

const { lang, slug } = Astro.params;
const currentLang = (lang || 'en') as 'en' | 'zh';
const currentPath = Astro.url.pathname;
const t = translations[currentLang];

export function getStaticPaths() {
  const en = translations['en'];
  const slugs = en.caseStudies.list.map((cs) => cs.slug);

  return slugs.flatMap((csSlug) => [
    { params: { lang: 'en', slug: csSlug } },
    { params: { lang: 'zh', slug: csSlug } },
  ]);
}

const caseStudy = t.caseStudies.list.find((cs) => cs.slug === slug);
const content = t.caseStudies[slug as keyof typeof t.caseStudies] as any;
const pageTitle = caseStudy?.title || t.caseStudies.listTitle;
---

<Layout title={pageTitle} lang={currentLang} currentLang={currentLang} currentPath={currentPath}>
  <main class="min-h-screen bg-gray-50">
    <article class="max-w-4xl mx-auto bg-white shadow my-8">
      <!-- Featured Image -->
      <div class="aspect-[16/9] overflow-hidden px-8">
        <AivioImage
          src={caseStudy?.image || '/assets/case/case-1.png'}
          alt={caseStudy?.title}
          className="w-full h-full object-cover"
        />
      </div>

      <!-- Article Content -->
      <div class="p-8">
        <!-- Title -->
        <h1 class="text-2xl md:text-3xl font-bold text-gray-900 mb-4">
          {content?.title}
        </h1>

        <!-- Meta Info -->
        <div class="flex items-center gap-4 text-sm text-secondary mb-8">
          <span class="flex items-center gap-1">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
            </svg>
            Aivio Digital
          </span>
          <span class="flex items-center gap-1">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
            </svg>
            {caseStudy?.date}
          </span>
        </div>

        <!-- Dynamic Content Sections -->
        {content?.client && (
          <section class="mb-12">
            <h2 class="text-2xl font-bold text-gray-900 mb-6">{content.client.title}</h2>
            <div class="bg-gray-50 rounded-lg p-6 space-y-2">
              <p class="text-gray-700">{content.client.industry}</p>
              <p class="text-gray-700">{content.client.location}</p>
              <p class="text-gray-700">{content.client.asset}</p>
            </div>
          </section>
        )}

        {content?.metadata && (
          <section class="mb-12">
            <div class="bg-gray-50 rounded-lg p-6 space-y-2">
              <p class="text-gray-700">{content.metadata.industry}</p>
              <p class="text-gray-700">{content.metadata.location}</p>
              <p class="text-gray-700">{content.metadata.spend}</p>
              <p class="text-gray-700">{content.metadata.type}</p>
            </div>
          </section>
        )}

        {content?.background && (
          <section class="mb-12">
            <h2 class="text-2xl font-bold text-gray-900 mb-4">{content.background.title}</h2>
            <p class="text-gray-600">{content.background.description}</p>
          </section>
        )}

        {content?.challenge && (
          <section class="mb-12">
            <h2 class="text-2xl font-bold text-secondary mb-4">{content.challenge.title}</h2>
            <div class="space-y-3">
              {(content.challenge.scenarios || content.challenge.points || []).map((item: string) => (
                <div class="flex gap-3">
                  <span class="text-secondary">•</span>
                  <p class="text-gray-700">{item}</p>
                </div>
              ))}
            </div>
          </section>
        )}

        {content?.diagnosis && (
          <section class="mb-12">
            <h2 class="text-2xl font-bold text-gray-900 mb-4">{content.diagnosis.title}</h2>
            {content.diagnosis.description && (
              <p class="text-gray-600 mb-6">{content.diagnosis.description}</p>
            )}
            <div class="space-y-6">
              {(content.diagnosis.items || [content.diagnosis.schema, content.diagnosis.footprint, content.diagnosis.semantic].filter(Boolean)).map((item: any) => (
                <div class="bg-white border border-gray-200 rounded-lg p-6">
                  <h3 class="font-bold text-gray-900 mb-2">{item.title}</h3>
                  <p class="text-gray-600">{item.description}</p>
                </div>
              ))}
            </div>
          </section>
        )}

        {content?.strategy && (
          <section class="mb-12">
            <h2 class="text-2xl font-bold text-gray-900 mb-4">{content.strategy.title}</h2>
            {content.strategy.intro && (
              <p class="text-gray-600 mb-6">{content.strategy.intro}</p>
            )}
            <div class="space-y-6">
              {(content.strategy.items || [content.strategy.entity, content.strategy.semantic, content.strategy.cleanup].filter(Boolean)).map((item: any) => (
                <div class="bg-secondary/5 rounded-lg p-6">
                  <h3 class="font-bold text-secondary mb-2">{item.title}</h3>
                  <p class="text-gray-700">{item.description}</p>
                </div>
              ))}
            </div>
          </section>
        )}

        {content?.optimization && (
          <section class="mb-12">
            <h2 class="text-2xl font-bold text-gray-900 mb-4">{content.optimization.title}</h2>
            {content.optimization.description && (
              <p class="text-gray-600 mb-6">{content.optimization.description}</p>
            )}
            <div class="space-y-6">
              {(content.optimization.items || []).map((item: any) => (
                <div class="bg-secondary/5 rounded-lg p-6">
                  <h3 class="font-bold text-secondary mb-3">{item.title}</h3>
                  {item.points ? (
                    <div class="space-y-2">
                      {item.points.map((point: string) => (
                        <div class="flex gap-3">
                          <span class="text-secondary">•</span>
                          <p class="text-gray-700">{point}</p>
                        </div>
                      ))}
                    </div>
                  ) : (
                    <p class="text-gray-700">{item.description}</p>
                  )}
                </div>
              ))}
            </div>
          </section>
        )}

        {content?.results && (
          <section class="mb-12">
            <h2 class="text-2xl font-bold text-gray-900 mb-6">{content.results.title}</h2>
            {content.results.metrics && (
              <div class="grid md:grid-cols-2 gap-4 mb-8">
                {content.results.metrics.map((metric: { value: string; label: string }) => (
                  <div class="text-center p-6 bg-white border border-gray-200 rounded-lg">
                    <div class="text-3xl font-bold text-secondary mb-2">{metric.value}</div>
                    <p class="text-sm text-gray-600">{metric.label}</p>
                  </div>
                ))}
              </div>
            )}
            {content.results.invisible && (
              <div class="space-y-6 mb-8">
                {[content.results.invisible, content.results.snippets, content.results.conversion].filter(Boolean).map((item: any) => (
                  <div class="bg-gray-50 rounded-lg p-6">
                    <h3 class="font-bold text-gray-900 mb-2">{item.title}</h3>
                    <p class="text-gray-600">{item.description}</p>
                  </div>
                ))}
              </div>
            )}
            {content.results.points && (
              <div class="space-y-3">
                {content.results.points.map((point: string) => (
                  <div class="flex gap-3">
                    <span class="text-secondary">•</span>
                    <p class="text-gray-700">{point}</p>
                  </div>
                ))}
              </div>
            )}
            {content.results.quote && (
              <blockquote class="mt-8 p-6 border-l-4 border-secondary bg-secondary/5 rounded-r-lg">
                <p class="text-gray-700 italic">{content.results.quote}</p>
              </blockquote>
            )}
          </section>
        )}

        {content?.takeaway && (
          <section class="mb-12">
            <h2 class="text-2xl font-bold text-gray-900 mb-4">{content.takeaway.title}</h2>
            <p class="text-gray-600">{content.takeaway.description}</p>
          </section>
        )}

        {content?.cta && (
          <section class="bg-secondary text-white rounded-xl p-8 text-center">
            <h2 class="text-2xl font-bold mb-4">{content.cta.title}</h2>
            <p class="text-white/80 mb-6">{content.cta.description}</p>
            <Button href={`/${currentLang}/contact`} variant="secondary">
            {content.cta.button}
            </Button>
          </section>
        )}
      </div>

      <!-- Back to Case Studies -->
      <div class="p-8 text-center border-t border-gray-100">
        <a
          href={`/${currentLang}/case-study`}
          class="inline-flex items-center gap-2 text-secondary font-semibold hover:underline"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
          </svg>
          {t.caseStudies.backToList}
        </a>
      </div>
    </article>
  </main>
</Layout>

<style>
  main {
    width: 100%;
  }
</style>
