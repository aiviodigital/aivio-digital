---
import Layout from '../../layouts/Layout.astro';
import { translations } from '../../i18n';
import Hero from '../../components/Hero.astro';
import ContactForm from '../../components/ContactForm.astro';

const { lang } = Astro.params;
const currentLang = (lang || 'en') as 'en' | 'zh';
const currentPath = Astro.url.pathname;
const t = translations[currentLang];
const pageTitle = t.pageTitle.contactUs;
const pageMeta = t.pageMeta.contactUs;
const content = t.contactUs;

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'zh' } },
  ];
}
---

<Layout title={pageTitle} description={pageMeta.description} keywords={pageMeta.keywords} lang={currentLang} currentLang={currentLang} currentPath={currentPath}>
  <main class="min-h-screen">
    <Hero title={content.hero.title} description={content.hero.description} image='/assets/contact.png' />

    <!-- Contact Form -->
    <section class="py-16 px-4 bg-white">
      <div class="max-w-2xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4 text-center">
          {content.form.title}
        </h2>
        <p class="text-lg text-gray-600 mb-8 text-center">
          {content.form.description}
        </p>
        
        <ContactForm labels={content.form} />
      </div>
    </section>


    <!-- How It Works -->
    <section class="py-16 px-4 bg-white">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-12 text-center">
          {content.howItWorks.title}
        </h2>
        <div class="space-y-8">
          <div class="flex gap-6">
            <span class="flex-shrink-0 w-12 h-12 bg-secondary text-white rounded flex items-center justify-center text-xl font-bold">1</span>
            <div>
              <p class="text-lg text-gray-700 leading-relaxed">
                {content.howItWorks.step1}
              </p>
            </div>
          </div>
          <div class="flex gap-6">
            <span class="flex-shrink-0 w-12 h-12 bg-secondary text-white rounded flex items-center justify-center text-xl font-bold">2</span>
            <div>
              <p class="text-lg text-gray-700 leading-relaxed">
                {content.howItWorks.step2}
              </p>
            </div>
          </div>
          <div class="flex gap-6">
            <span class="flex-shrink-0 w-12 h-12 bg-secondary text-white rounded flex items-center justify-center text-xl font-bold">3</span>
            <div>
              <p class="text-lg text-gray-700 leading-relaxed">
                {content.howItWorks.step3}
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Services & Pricing -->
    <section class="py-16 px-4 bg-gray-50">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-12 text-center">
          {content.servicesPricing.title}
        </h2>
        <div class="grid md:grid-cols-2 gap-8">
          <div class="bg-white p-8 rounded-lg shadow-md">
            <h3 class="text-2xl font-bold text-gray-900 mb-4">
              {content.servicesPricing.audit.title}
            </h3>
            <p class="text-gray-700 leading-relaxed mb-4">
              {content.servicesPricing.audit.description}
            </p>
          </div>
          <div class="bg-white p-8 rounded-lg shadow-md">
            <h3 class="text-2xl font-bold text-gray-900 mb-4">
              {content.servicesPricing.management.title}
            </h3>
            <p class="text-gray-700 leading-relaxed mb-4">
              {content.servicesPricing.management.description}
            </p>
          </div>
        </div>
        <!-- <div class="mt-8 bg-secondary/10 p-6 rounded-lg text-center">
          <p class="text-lg text-gray-700">
            {content.servicesPricing.both}
          </p>
        </div> -->
      </div>
    </section>

    <!-- After You Submit -->
    <section class="py-16 px-4 bg-gray-50">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-6 text-center">
          {content.afterSubmit.title}
        </h2>
        <p class="text-lg text-gray-700 mb-8 text-center">
          {content.afterSubmit.description}
        </p>
        <div class="grid md:grid-cols-2 gap-6">
          <div class="bg-white p-6 rounded-lg shadow-md">
            <h3 class="text-xl font-semibold text-gray-900 mb-3">
              {content.afterSubmit.auditNote}
            </h3>
          </div>
          <div class="bg-white p-6 rounded-lg shadow-md">
            <h3 class="text-xl font-semibold text-gray-900 mb-3">
              {content.afterSubmit.managementNote}
            </h3>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  main {
    width: 100%;
  }
</style>
