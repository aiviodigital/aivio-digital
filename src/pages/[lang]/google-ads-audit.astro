---
import Layout from '../../layouts/Layout.astro';
import { translations } from '../../i18n';
import Button from '../../components/Button.astro';
import FAQSection from '../../components/FAQSection.astro';
import { EMAIL } from '../../constants/contact';

const { lang } = Astro.params;
const currentLang = (lang || 'en') as 'en' | 'zh';
const currentPath = Astro.url.pathname;
const t = translations[currentLang];
const pageTitle = t.pageTitle.googleAdsAudit;
const pageMeta = t.pageMeta.googleAdsAudit;
const content = t.googleAdsAudit;

const faqItems = [
  {
    question: 'What does a Google Ads audit include?',
    answer: 'Our audit examines campaign structure, keyword targeting, ad copy effectiveness, bidding strategies, and conversion tracking to identify performance gaps and optimization opportunities.',
  },
  {
    question: 'How long does the audit take?',
    answer: 'Most audits are completed within 5-7 business days, depending on account complexity and campaign volume.',
  },
  {
    question: 'Will I receive actionable recommendations?',
    answer: 'Yes, you will receive a detailed report with prioritized, actionable recommendations tailored to your business goals.',
  },
  {
    question: 'Do you require account access?',
    answer: 'Yes, we need read-only access to your Google Ads account to conduct a thorough audit and provide accurate recommendations.',
  },
  {
    question: 'Can audits help reduce ad spend waste?',
    answer: 'Absolutely. Our audits identify wasted budget on low-performing keywords, poor targeting, and inefficient bidding strategies, helping you optimize spending.',
  },
];

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'zh' } },
  ];
}
---

<Layout title={pageTitle} description={pageMeta.description} keywords={pageMeta.keywords} lang={currentLang} currentLang={currentLang} currentPath={currentPath}>
  <main class="min-h-screen">
    <!-- Hero Section with Beige Background -->
    <section class="bg-[#E8D5B7] py-20 px-4">
      <div class="max-w-4xl mx-auto text-center">
        <h1 class="text-4xl md:text-5xl font-bold text-secondary mb-6">
          Google Ads Audit Overview
        </h1>
        <p class="text-lg text-gray-700 max-w-2xl mx-auto leading-relaxed">
          A comprehensive evaluation of your Google Ads campaigns focusing on key performance metrics and tailored strategic recommendations.
        </p>
      </div>
    </section>

    <!-- Dark Green Section with Images -->
    <section class="bg-secondary py-16 px-4">
      <div class="max-w-7xl mx-auto">
        <div class="grid md:grid-cols-3 gap-6">
          <!-- Image 1 - Analytics Dashboard -->
          <div class="aspect-video bg-gray-700 rounded-lg overflow-hidden shadow-xl">
            <img
              src="/assets/audit/analytics-dashboard.jpg"
              alt="Analytics Dashboard"
              class="w-full h-full object-cover"
              onerror="this.style.display='none'; this.parentElement.classList.add('flex', 'items-center', 'justify-center'); this.parentElement.innerHTML='<div class=\'text-white text-center p-8\'><svg class=\'w-16 h-16 mx-auto mb-4 opacity-50\' fill=\'none\' stroke=\'currentColor\' viewBox=\'0 0 24 24\'><path stroke-linecap=\'round\' stroke-linejoin=\'round\' stroke-width=\'2\' d=\'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z\'></path></svg><p class=\'text-sm\'>Analytics Dashboard</p></div>';"
            />
          </div>

          <!-- Image 2 - Dual Monitors -->
          <div class="aspect-video bg-gray-700 rounded-lg overflow-hidden shadow-xl">
            <img
              src="/assets/audit/dual-monitors.jpg"
              alt="Performance Analysis"
              class="w-full h-full object-cover"
              onerror="this.style.display='none'; this.parentElement.classList.add('flex', 'items-center', 'justify-center'); this.parentElement.innerHTML='<div class=\'text-white text-center p-8\'><svg class=\'w-16 h-16 mx-auto mb-4 opacity-50\' fill=\'none\' stroke=\'currentColor\' viewBox=\'0 0 24 24\'><path stroke-linecap=\'round\' stroke-linejoin=\'round\' stroke-width=\'2\' d=\'M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z\'></path></svg><p class=\'text-sm\'>Performance Analysis</p></div>';"
            />
          </div>

          <!-- Image 3 - Team Presentation -->
          <div class="aspect-video bg-gray-700 rounded-lg overflow-hidden shadow-xl">
            <img
              src="/assets/audit/team-presentation.jpg"
              alt="Strategic Planning"
              class="w-full h-full object-cover"
              onerror="this.style.display='none'; this.parentElement.classList.add('flex', 'items-center', 'justify-center'); this.parentElement.innerHTML='<div class=\'text-white text-center p-8\'><svg class=\'w-16 h-16 mx-auto mb-4 opacity-50\' fill=\'none\' stroke=\'currentColor\' viewBox=\'0 0 24 24\'><path stroke-linecap=\'round\' stroke-linejoin=\'round\' stroke-width=\'2\' d=\'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z\'></path></svg><p class=\'text-sm\'>Strategic Planning</p></div>';"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ Section -->
    <section class="py-20 px-4 bg-white">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-12">
          <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
            Google Ads Audit FAQs
          </h2>
          <p class="text-base text-gray-600 max-w-2xl mx-auto">
            Clarify your questions about our Google Ads audit process, what to expect, and how it can pinpoint opportunities for your campaigns.
          </p>
        </div>
        <div class="space-y-4">
          {faqItems.map((item) => (
            <details class="bg-white rounded shadow-md group border border-gray-200">
              <summary class="p-6 cursor-pointer font-semibold text-gray-900 flex justify-between items-center transition-all duration-300 ease-in-out hover:translate-x-1">
                <span class="text-base">{item.question}</span>
                <svg class="w-5 h-5 text-secondary flex-shrink-0 ml-4 transform transition-transform duration-300 ease-out group-open:rotate-180 group-open:text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                </svg>
              </summary>
              <div class="grid-wrapper">
                <div class="px-6 pb-6 text-gray-600 animate-fade-in">
                  {item.answer}
                </div>
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- Need More Answers Section -->
    <section class="py-20 px-4 bg-gray-50">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-6">
          Need More Answers?
        </h2>
        <p class="text-lg text-gray-600 mb-8 max-w-2xl mx-auto leading-relaxed">
          Contact our team for personalized responses to your Google Ads audit questions and to discuss how we can support your campaign goals.
        </p>
        <Button
          href={`mailto:${EMAIL}?subject=Google Ads Audit Inquiry`}
          variant="secondary"
          size="lg"
        >
          Contact us
        </Button>
      </div>
    </section>
  </main>
</Layout>

<style>
  main {
    width: 100%;
  }

  /* FAQ Accordion Styles */
  details > summary {
    list-style: none;
  }
  details > summary::-webkit-details-marker {
    display: none;
  }
  details .grid-wrapper {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.3s ease-out;
  }
  details[open] .grid-wrapper {
    grid-template-rows: 1fr;
    transition: grid-template-rows 0.5s ease-in-out;
  }
  details .grid-wrapper > div {
    overflow: hidden;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(-10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-fade-in {
    animation: fadeIn 0.3s ease-out 0.1s both;
  }

  details:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1);
  }
</style>
