---
import Layout from '../../layouts/Layout.astro';
import { translations } from '../../i18n';
import Button from '../../components/Button.astro';
import FAQSection from '../../components/FAQSection.astro';
import { EMAIL } from '../../constants/contact';
import Hero from '../../components/Hero.astro';
import StepsSection from '../../components/google-ads-audit/StepsSection.astro';
import CTASection from '../../components/google-ads-audit/CTASection.astro';
import SystemCheckSection from '../../components/google-ads-audit/SystemCheckSection.astro';
import AivioImage from '@/components/common/AivioImage.astro';

const { lang } = Astro.params;
const currentLang = (lang || 'en') as 'en' | 'zh';
const currentPath = Astro.url.pathname;
const t = translations[currentLang];
const pageTitle = t.pageTitle.googleAdsAudit;
const pageMeta = t.pageMeta.googleAdsAudit;
const content = t.googleAdsAudit.page;

const afterAuditSteps = [
  { step: '1', title: 'Implement Recommendations', icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z' },
  { step: '2', title: 'Continue Self-Management', icon: 'M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31 2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z' },
  { step: '3', title: 'Partner with Us', icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z' },
];

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'zh' } },
  ];
}
---

<Layout title={pageTitle} description={pageMeta.description} keywords={pageMeta.keywords} lang={currentLang} currentLang={currentLang} currentPath={currentPath}>
  <main class="min-h-screen">
    <Hero
      title={content.hero.title}
      subtitle={content.hero.subtitle}
      image="/assets/audit/audit-hero.png"
    />

    <!-- The Problem (Agitation) Section -->
    <section class="py-16 px-4 bg-white border-b border-gray-200">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-6">
          {content.problem.headline}
        </h2>
        <p class="text-lg text-gray-600 mb-6 leading-relaxed">
          {content.problem.description}
        </p>
        <ul class="space-y-4">
          {content.problem.points.map((point) => (
            <li class="flex items-start gap-3">
              <svg class="w-6 h-6 text-secondaryDark flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
              </svg>
              <span class="text-gray-700 text-lg">{point}</span>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- 4-Step System Check Section -->
    <SystemCheckSection content={content} badge={content.systemCheck.badge} lang={currentLang} />

    <!-- Dark Green Section with Images -->
    <section class="bg-secondary py-16 px-4">
      <div class="max-w-7xl mx-auto">
        <div class="grid md:grid-cols-3 gap-6">
          <!-- Image 1 -->
          <div class="aspect-[4/3] rounded-lg overflow-hidden shadow-xl">
            <AivioImage
              src="/assets/audit/Audit-1.png"
              alt={content.images.alt.analytics}
              className="w-full h-full object-cover"
            />
          </div>

          <!-- Image 2 -->
          <div class="aspect-[4/3] rounded-lg overflow-hidden shadow-xl">
            <AivioImage
              src="/assets/audit/Audit-2.png"
              alt={content.images.alt.performance}
              className="w-full h-full object-cover"
            />
          </div>

          <!-- Image 3 -->
          <div class="aspect-[4/3] rounded-lg overflow-hidden shadow-xl">
            <AivioImage
              src="/assets/audit/Audit-3.png"
              alt={content.images.alt.strategic}
              className="w-full h-full object-cover"
            />
          </div>
        </div>
      </div>
    </section>

     <!-- What Happens After -->
    <StepsSection
      title={content.afterAudit.title}
      subtitle={content.afterAudit.subtitle}
      steps={afterAuditSteps}
      options={[content.afterAudit.option1, content.afterAudit.option2, content.afterAudit.option3]}
      note={content.afterAudit.note}
    />

    <!-- FAQ Section -->
    <FAQSection
      items={content.faq.items}
      title={content.faq.title}
      backgroundColor="white"
    />

    <!-- Ready CTA -->
    <CTASection
      title={content.ready.title}
      subtitle={content.ready.subtitle}
      buttonText={content.ready.button}
      bgColor="from-primary to-primaryDark"
    />

    <!-- Need More Answers Section -->
    <section class="py-20 px-4 bg-gray-50">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-6">
          {content.contact.title}
        </h2>
        <p class="text-lg text-gray-600 mb-8 max-w-2xl mx-auto leading-relaxed">
          {content.contact.subtitle}
        </p>
        <Button
          href={`mailto:${EMAIL}?subject=Google Ads Audit Inquiry`}
          variant="secondary"
          size="lg"
        >
          {content.contact.button}
        </Button>
      </div>
    </section>
  </main>
</Layout>

<style>
  main {
    width: 100%;
  }
</style>
