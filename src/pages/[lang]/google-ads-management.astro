---
import Layout from '../../layouts/Layout.astro';
import { translations } from '../../i18n';
import Button from '../../components/Button.astro';
import { EMAIL } from '../../constants/contact';

const { lang } = Astro.params;
const currentLang = (lang || 'en') as 'en' | 'zh';
const currentPath = Astro.url.pathname;
const t = translations[currentLang];
const pageTitle = t.pageTitle.googleAdsManagement;
const pageMeta = t.pageMeta.googleAdsManagement;
const content = t.googleAdsManagement;

const faqItems = [
  { question: content.faq.q1.question, answer: content.faq.q1.answer },
  { question: content.faq.q2.question, answer: content.faq.q2.answer },
  { question: content.faq.q3.question, answer: content.faq.q3.answer },
  { question: content.faq.q4.question, answer: content.faq.q4.answer },
  { question: content.faq.q5.question, answer: content.faq.q5.answer },
  { question: content.faq.q6.question, answer: content.faq.q6.answer },
];

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'zh' } },
  ];
}
---

<Layout title={pageTitle} description={pageMeta.description} keywords={pageMeta.keywords} lang={currentLang} currentLang={currentLang} currentPath={currentPath}>
  <main class="min-h-screen">
    <!-- Hero Section -->
    <section class="grid md:grid-cols-2 min-h-[600px]">
      <!-- Left Side - Text Content with Beige Background -->
      <div class="bg-[#E8D5B7] flex items-center px-8 md:px-16 py-16">
        <div class="max-w-xl">
          <p class="text-xs md:text-sm text-gray-700 uppercase tracking-wider mb-6 font-medium">
            Maximize your ad spend with precision-driven Google Ads management
          </p>
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-gray-900 leading-tight mb-8">
            Strategic Google Ads Management for Optimal ROI
          </h1>
        </div>
      </div>

      <!-- Right Side - Hero Image -->
      <div class="relative bg-gray-200 min-h-[400px] md:min-h-full">
        <img
          src="/assets/mgmt/hero.jpg"
          alt="Google Ads Management Dashboard"
          class="absolute inset-0 w-full h-full object-cover"
          onerror="this.style.display='none'"
        />
      </div>
    </section>

    <!-- Service Cards Section -->
    <section class="relative py-20 px-4 bg-gray-50">
      <!-- Background Image -->
      <div class="absolute inset-0 overflow-hidden">
        <img
          src="/assets/mgmt/services-bg.jpg"
          alt="Professional working"
          class="w-full h-full object-cover opacity-40"
          onerror="this.style.display='none'"
        />
      </div>

      <div class="relative z-10 max-w-7xl mx-auto">
        <div class="grid md:grid-cols-2 gap-8">
          <!-- Card 1: Precision-Driven Campaigns -->
          <div class="bg-white/95 backdrop-blur-sm p-8 rounded-lg shadow-lg hover:shadow-xl transition-shadow">
            <h3 class="text-2xl font-bold text-gray-900 mb-4">
              Precision-Driven Campaigns
            </h3>
            <p class="text-gray-700 mb-6 leading-relaxed">
              Data-backed targeted strategies that align with your business goals to reach the right audience effectively.
            </p>
            <button class="text-secondary font-semibold hover:text-secondaryDark transition-colors uppercase text-sm tracking-wider">
              Learn More
            </button>
          </div>

          <!-- Card 2: Data-Backed Optimization -->
          <div class="bg-white/95 backdrop-blur-sm p-8 rounded-lg shadow-lg hover:shadow-xl transition-shadow">
            <h3 class="text-2xl font-bold text-gray-900 mb-4">
              Data-Backed Optimization
            </h3>
            <p class="text-gray-700 mb-6 leading-relaxed">
              Continuous performance tracking and adjustment ensure your ads deliver measurable results and marketing ROI.
            </p>
            <button class="text-secondary font-semibold hover:text-secondaryDark transition-colors uppercase text-sm tracking-wider">
              Explore Services
            </button>
          </div>

          <!-- Card 3: Comprehensive Management -->
          <div class="bg-white/95 backdrop-blur-sm p-8 rounded-lg shadow-lg hover:shadow-xl transition-shadow">
            <h3 class="text-2xl font-bold text-gray-900 mb-4">
              Comprehensive Management
            </h3>
            <p class="text-gray-700 mb-6 leading-relaxed">
              From keyword selection to bid management, we handle every aspect of your Google Ads campaigns with expert oversight.
            </p>
            <button class="text-secondary font-semibold hover:text-secondaryDark transition-colors uppercase text-sm tracking-wider">
              Get Started
            </button>
          </div>

          <!-- Card 4: Transparent Reporting -->
          <div class="bg-white/95 backdrop-blur-sm p-8 rounded-lg shadow-lg hover:shadow-xl transition-shadow">
            <h3 class="text-2xl font-bold text-gray-900 mb-4">
              Transparent Reporting
            </h3>
            <p class="text-gray-700 mb-6 leading-relaxed">
              Receive detailed insights and clear analytics to understand campaign performance and strategic decisions.
            </p>
            <button class="text-secondary font-semibold hover:text-secondaryDark transition-colors uppercase text-sm tracking-wider">
              Request Report
            </button>
          </div>
        </div>
      </div>
    </section>

    <!-- Image Showcase Section -->
    <section class="bg-secondary py-16">
      <div class="max-w-7xl mx-auto px-4">
        <div class="grid md:grid-cols-3 gap-8">
          <!-- Image 1 -->
          <div class="relative aspect-[4/3] rounded-lg overflow-hidden shadow-xl">
            <img
              src="/assets/mgmt/team-meeting.jpg"
              alt="Team collaboration"
              class="w-full h-full object-cover"
              onerror="this.style.display='none'; this.parentElement.classList.add('bg-gray-700')"
            />
          </div>

          <!-- Image 2 -->
          <div class="relative aspect-[4/3] rounded-lg overflow-hidden shadow-xl">
            <img
              src="/assets/mgmt/analytics-screen.jpg"
              alt="Analytics dashboard"
              class="w-full h-full object-cover"
              onerror="this.style.display='none'; this.parentElement.classList.add('bg-gray-700')"
            />
          </div>

          <!-- Image 3 -->
          <div class="relative aspect-[4/3] rounded-lg overflow-hidden shadow-xl">
            <img
              src="/assets/mgmt/performance-charts.jpg"
              alt="Performance metrics"
              class="w-full h-full object-cover"
              onerror="this.style.display='none'; this.parentElement.classList.add('bg-gray-700')"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ Section -->
    <section class="py-20 px-4 bg-white">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-12">
          <h2 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">
            Google Ads Management FAQs
          </h2>
          <p class="text-lg text-gray-600 max-w-3xl mx-auto">
            Clear answers to common questions about managing Google Ads campaigns help you make informed decisions and optimize your advertising investment.
          </p>
        </div>

        <div class="space-y-4">
          {faqItems.map((item) => (
            <details class="bg-white rounded shadow-md group border border-gray-200">
              <summary class="p-6 cursor-pointer font-semibold text-gray-900 flex justify-between items-center transition-all duration-300 ease-in-out hover:translate-x-1">
                <span class="text-lg">{item.question}</span>
                <svg class="w-5 h-5 text-secondary flex-shrink-0 ml-4 transform transition-transform duration-300 ease-out group-open:rotate-180 group-open:text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                </svg>
              </summary>
              <div class="grid-wrapper">
                <div class="px-6 pb-6 text-gray-600 animate-fade-in">
                  {item.answer}
                </div>
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- Need More Information Section -->
    <section class="py-16 px-4 bg-gray-50">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-6">
          Need More Information?
        </h2>
        <p class="text-lg text-gray-600 mb-8 max-w-2xl mx-auto">
          Contact our team to discuss your specific Google Ads needs and how our management services can deliver measurable growth.
        </p>
        <Button
          href={`mailto:${EMAIL}?subject=Google Ads Management Inquiry`}
          variant="secondary"
          size="lg"
        >
          Get In Touch
        </Button>
      </div>
    </section>

    <!-- Final CTA Section with Background Image -->
    <section class="relative py-32 px-4 overflow-hidden">
      <!-- Background Image -->
      <div class="absolute inset-0">
        <img
          src="/assets/mgmt/cta-bg.jpg"
          alt="Start optimizing"
          class="w-full h-full object-cover"
          onerror="this.style.display='none'; this.parentElement.classList.add('bg-secondary')"
        />
        <div class="absolute inset-0 bg-secondary/80"></div>
      </div>

      <!-- Content -->
      <div class="relative z-10 max-w-4xl mx-auto text-center">
        <h2 class="text-4xl md:text-5xl font-bold text-white mb-8">
          Start Optimizing Your Google Ads Campaign Today
        </h2>
        <Button
          href={`/${currentLang}/contact`}
          variant="primary"
          size="lg"
        >
          Request Consultation
        </Button>
      </div>
    </section>
  </main>
</Layout>

<style>
  details > summary {
    list-style: none;
  }
  details > summary::-webkit-details-marker {
    display: none;
  }
  details .grid-wrapper {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.3s ease-out;
  }
  details[open] .grid-wrapper {
    grid-template-rows: 1fr;
    transition: grid-template-rows 0.5s ease-in-out;
  }
  details .grid-wrapper > div {
    overflow: hidden;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(-10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-fade-in {
    animation: fadeIn 0.3s ease-out 0.1s both;
  }

  details:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1);
  }
</style>
