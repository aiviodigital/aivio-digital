---
import Layout from '../../layouts/Layout.astro';
import { translations } from '../../i18n';
import Button from '../../components/Button.astro';
import FAQSection from '../../components/FAQSection.astro';
import { EMAIL } from '../../constants/contact';
import Hero from '../../components/Hero.astro';
import TwoPathsSection from '../../components/google-ads-management/TwoPathsSection.astro';
import WhatsIncludedSection from '../../components/google-ads-management/WhatsIncludedSection.astro';

const { lang } = Astro.params;
const currentLang = (lang || 'en') as 'en' | 'zh';
const currentPath = Astro.url.pathname;
const t = translations[currentLang];
const pageTitle = t.pageTitle.googleAdsManagement;
const pageMeta = t.pageMeta.googleAdsManagement;
const content = t.googleAdsManagement.page;

const faqItems = [
  { question: t.googleAdsManagement.faq.q1.question, answer: t.googleAdsManagement.faq.q1.answer },
  { question: t.googleAdsManagement.faq.q2.question, answer: t.googleAdsManagement.faq.q2.answer },
  { question: t.googleAdsManagement.faq.q3.question, answer: t.googleAdsManagement.faq.q3.answer },
  { question: t.googleAdsManagement.faq.q4.question, answer: t.googleAdsManagement.faq.q4.answer },
  { question: t.googleAdsManagement.faq.q5.question, answer: t.googleAdsManagement.faq.q5.answer },
  { question: t.googleAdsManagement.faq.q6.question, answer: t.googleAdsManagement.faq.q6.answer },
];

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'zh' } },
  ];
}
---

<Layout title={pageTitle} description={pageMeta.description} keywords={pageMeta.keywords} lang={currentLang} currentLang={currentLang} currentPath={currentPath}>
  <main class="min-h-screen">
    <!-- Hero Section -->
    <Hero title={content.hero.title} subtitle={content.hero.subtitle} image="/assets/mgmt/mgmt-1.png" />

    <!-- Service Cards Section -->
    <section class="relative py-20 px-4 bg-gray-50">
      <!-- Background Image -->
      <div class="absolute inset-0 overflow-hidden bg-gray-100">
        <img
          src="/assets/mgmt/mgmt-4.png"
          alt={content.images.bgAlt}
          class="w-full h-full object-cover opacity-40 transition-opacity duration-300"
          loading="lazy"
          onerror="this.style.opacity='0'"
        />
      </div>

      <div class="relative z-10 max-w-7xl mx-auto">
        <div class="grid md:grid-cols-2 gap-8">
          {content.services.cards.map((card, index) => (
            <div 
              class="bg-white/95 backdrop-blur-sm p-8 rounded-lg shadow-lg hover:shadow-xl transition-shadow"
            >
              <h3 class="text-2xl font-bold text-gray-900 mb-4">
                {card.title}
              </h3>
              <p class="text-gray-700 mb-6 leading-relaxed">
                {card.description}
              </p>
              <button 
                type="button"
                class="text-secondary font-semibold hover:text-secondaryDark transition-colors uppercase text-sm tracking-wider"
                aria-label={`Learn more about ${card.title}`}
              >
                {card.button}
              </button>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Image Showcase Section -->
    <section class="bg-secondary py-16">
      <div class="max-w-7xl mx-auto px-4">
        <div class="grid md:grid-cols-3 gap-8">
          <!-- Image 1 -->
          <div class="relative aspect-[4/3] rounded-lg overflow-hidden shadow-xl bg-gray-100">
            <img
              src="/assets/mgmt/mgmt-5.png"
              alt={content.images.alt.team}
              class="w-full h-full object-cover transition-opacity duration-300 hover:opacity-95"
              loading="lazy"
              onerror="this.style.opacity='0'"
            />
          </div>

          <!-- Image 2 -->
          <div class="relative aspect-[4/3] rounded-lg overflow-hidden shadow-xl bg-gray-100">
            <img
              src="/assets/mgmt/mgmt-3.png"
              alt={content.images.alt.analytics}
              class="w-full h-full object-cover transition-opacity duration-300 hover:opacity-95"
              loading="lazy"
              onerror="this.style.opacity='0'"
            />
          </div>

          <!-- Image 3 -->
          <div class="relative aspect-[4/3] rounded-lg overflow-hidden shadow-xl bg-gray-100">
            <img
              src="/assets/mgmt/mgmt-2.png"
              alt={content.images.alt.performance}
              class="w-full h-full object-cover transition-opacity duration-300 hover:opacity-95"
              loading="lazy"
              onerror="this.style.opacity='0'"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- Two Paths Section -->
    <TwoPathsSection content={content} />

    <!-- What's Included Section -->
    <WhatsIncludedSection content={content} />

    <!-- FAQ Section -->
    <FAQSection items={faqItems} title={content.faq.title} variant="gradient" backgroundColor="white" />

    <!-- Need More Information Section -->
    <section class="py-16 px-4 bg-gray-50">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-6">
          {content.contact.title}
        </h2>
        <p class="text-lg text-gray-600 mb-8 max-w-2xl mx-auto">
          {content.contact.subtitle}
        </p>
        <Button
          href={`mailto:${EMAIL}?subject=Google Ads Management Inquiry`}
          variant="secondary"
          size="lg"
        >
          {content.contact.button}
        </Button>
      </div>
    </section>

    <!-- Final CTA Section with Background Image -->
    <section class="relative py-32 px-4 overflow-hidden">
      <!-- Background Image -->
      <div class="absolute inset-0 bg-secondary">
        <img
          src="/assets/mgmt/mgmt-hero.png"
          alt={content.cta.alt}
          class="w-full h-full object-cover transition-opacity duration-500"
          loading="lazy"
          onerror="this.style.opacity='0'"
        />
        <div class="absolute inset-0 bg-black/10"></div>
      </div>

      <!-- Content -->
      <div class="relative z-10 max-w-4xl mx-auto text-center">
        <h2 class="text-4xl md:text-5xl font-bold text-secondary mb-8">
          {content.cta.title}
        </h2>
        <Button
          href={`/${currentLang}/contact`}
          variant="primary"
          size="lg"
        >
          {content.cta.button}
        </Button>
      </div>
    </section>
  </main>
</Layout>
