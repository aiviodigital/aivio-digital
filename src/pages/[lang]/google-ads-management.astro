---
import Layout from '../../layouts/Layout.astro';
import { translations } from '../../i18n';
import Button from '../../components/Button.astro';
import FAQSection from '../../components/FAQSection.astro';
import { EMAIL } from '../../constants/contact';
import Hero from '../../components/Hero.astro';
import TwoPathsSection from '../../components/google-ads-management/TwoPathsSection.astro';
import WhatsIncludedSection from '../../components/google-ads-management/WhatsIncludedSection.astro';
import ProcessCards from '@/components/google-ads-management/ProcessCards.astro';
import AivioImage from '@/components/common/AivioImage.astro';

const { lang } = Astro.params;
const currentLang = (lang || 'en') as 'en' | 'zh';
const currentPath = Astro.url.pathname;
const t = translations[currentLang];
const pageTitle = t.pageTitle.googleAdsManagement;
const pageMeta = t.pageMeta.googleAdsManagement;
const content = t.googleAdsManagement.page;

const faqItems = [
  { question: t.googleAdsManagement.faq.q1.question, answer: t.googleAdsManagement.faq.q1.answer },
  { question: t.googleAdsManagement.faq.q2.question, answer: t.googleAdsManagement.faq.q2.answer },
  { question: t.googleAdsManagement.faq.q3.question, answer: t.googleAdsManagement.faq.q3.answer },
  { question: t.googleAdsManagement.faq.q4.question, answer: t.googleAdsManagement.faq.q4.answer },
  { question: t.googleAdsManagement.faq.q5.question, answer: t.googleAdsManagement.faq.q5.answer },
  { question: t.googleAdsManagement.faq.q6.question, answer: t.googleAdsManagement.faq.q6.answer },
];

const howWeManageItems = [
  {
    icon: 'M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z',
    title: content.howWeManage.structure.title,
    description: content.howWeManage.structure.description,
  },
  {
    icon: 'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 1v8m0 1v8m0 1v8m0 1v8',
    title: content.howWeManage.bidding.title,
    description: content.howWeManage.bidding.description,
  },
  {
    icon: 'M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z',
    title: content.howWeManage.adCopy.title,
    description: content.howWeManage.adCopy.description,
  },
  {
    icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z',
    title: content.howWeManage.monitoring.title,
    description: content.howWeManage.monitoring.description,
  },
  {
    icon: 'M13 10V3L4 14h7v7l9-11h-7z',
    title: content.howWeManage.optimization.title,
    description: content.howWeManage.optimization.description,
  },
];

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'zh' } },
  ];
}
---

<Layout title={pageTitle} description={pageMeta.description} keywords={pageMeta.keywords} lang={currentLang} currentLang={currentLang} currentPath={currentPath}>
  <main class="min-h-screen">
    <!-- Hero Section -->
    <Hero title={content.hero.title} subtitle={content.hero.subtitle} image="/assets/mgmt/mgmt-1.png" />

    <!-- Service Cards Section -->
    <section class="relative py-20 px-4 bg-gray-50">
      <!-- Background Image -->
      <div class="absolute inset-0 overflow-hidden bg-gray-100">
        <AivioImage
          src="/assets/mgmt/mgmt-4.png"
          alt={content.images.bgAlt}
          className="w-full h-full object-cover opacity-40 transition-opacity duration-300"
        />
      </div>

      <div class="relative z-10 max-w-7xl mx-auto">
        <div class="grid md:grid-cols-2 gap-8">
          {content.services.cards.map((card, index) => (
            <div 
              class="bg-white/95 backdrop-blur-sm p-8 rounded-lg shadow-lg hover:shadow-xl transition-shadow"
            >
              <h3 class="text-2xl font-bold text-secondary mb-4">
                {card.title}
              </h3>
              <p class="text-gray-700 mb-6 leading-relaxed">
                {card.description}
              </p>
              {/* <button 
                type="button"
                class="text-secondary font-semibold hover:text-secondaryDark transition-colors uppercase text-sm tracking-wider"
                aria-label={`Learn more about ${card.title}`}
              >
                {card.button}
              </button> */}
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Two Paths Section -->
    <TwoPathsSection content={content} />

    <!-- What's Included Section -->
    <WhatsIncludedSection content={content} />

    <ProcessCards
      items={howWeManageItems}
      title={content.howWeManage.title}
      subtitle={content.howWeManage.subtitle}
    />

    <!-- FAQ Section -->
    <FAQSection items={faqItems} title={content.faq.title} variant="gradient" backgroundColor="white" />

    <!-- Final CTA Section with Background Image -->
    <section class="relative py-32 px-4 overflow-hidden">
      <!-- Background Image -->
      <div class="absolute inset-0 bg-secondary">
        <AivioImage
          src="/assets/mgmt/mgmt-hero.png"
          alt={content.cta.alt}
          className="w-full h-full object-cover transition-opacity duration-500"
        />
        <div class="absolute inset-0 bg-primary/90 backdrop-blur-sm"></div>
      </div>

      <!-- Content -->
      <div class="relative z-10 max-w-4xl mx-auto text-center">
        <h2 class="text-4xl md:text-5xl font-bold text-secondary mb-8">
          {content.cta.title}
        </h2>
        <Button
          href={`/${currentLang}/contact`}
          variant="primary"
          size="lg"
        >
          {content.cta.button}
        </Button>
      </div>
    </section>
  </main>
</Layout>
